---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Illustration / Apparel / Collaboration</div>\n      <h1>Kryoz Gardening</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nA spiritual, psychedelic illustration created for Kryoz Gardening — a limited apparel collection developed with creative direction from Ed at Revolt Enterprises.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2827726989636709458265167223257/Kryoz-1.jpg\" alt=\"Kryoz on a phone wearing a shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2827726989692049690486295878105/Kryoz-4.jpg\" alt=\"Kryoz shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2827726989655156202338876774873/Kryoz-2.jpg\" alt=\"Close up of Kryoz shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/B2827726989673602946412586326489/Kryoz-3.jpg\" alt=\"Illustartion for a t-shirt for Kryoz\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Kryoz Gardening</strong> was created as a bold, surreal illustration piece for a limited apparel collection. The visual direction leaned into spiritual, psychedelic, and playful garden-inspired themes, giving the release a strong identity that felt distinct, characterful, and collectible.\n        </p>\n\n        <p>\nThe project was developed in collaboration with Ed from Revolt Enterprises, who led the creative direction for the collection. The final artwork was applied across the apparel release and helped shape the overall feel of the drop.\n        </p>\n\n        <p>\nThe collection has since been released and sold out.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Kryoz Gardening</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Illustration / Apparel Graphic</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Creative Direction</div>\n          <div class=\"portfolio-project-ctm__value\">Ed / Revolt Enterprises</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Outcome</div>\n          <div class=\"portfolio-project-ctm__value\">Released + Sold Out</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/archive\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Archive</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/pinos-restaurant\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Pino’s Restaurant</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Kryoz | Mitch Chadban"
  description="Design, SEO and marketing for brands, SaaS companies and service businesses that need sharper websites, stronger content and cleaner growth systems."
  canonical="https://mitchchadban.com/kryoz/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
