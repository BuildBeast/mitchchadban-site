h=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/J2861405249712773072167810226649/L-25.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405249694326328094100675033/L-23_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861405249675879584020391123417/L-21.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405249657432839946681571801/L-20.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2861405249638986095872972020185/L-19.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405249620539351799262468569/L-17.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861405249602092607725552916953/L-16.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405249583645863651843365337/L-15.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405249565199119578133813721/L-14.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405249546752375504424262105/L-13.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2861405249528305631430714710489/L-11.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405249509858887357005158873/L-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405249491412143283295607257/L-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405249472965399209586055641/L-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/R2861405249454518655135876504025/L-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405249436071911062166952409/L-3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405249417625166988457400793/L-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"></div>\n          <div class=\"archive-ctm__text\">\nArtwork and creative direction for various logo designs for many different clients over the years.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Uno House Party</span>\n          <span class=\"archive-ctm__meta\">Hospitality / Event Campaign</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405250487536323263611394521/RE-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861405250579770043632159152601/RE-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405250561323299558449600985/RE-5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861405250542876555484740049369/RE-4_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405250524429811411030497753/RE-3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2861405250505983067337320946137/RE-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__video\">\n            <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/h1cRD18q880\" title=\"Uno House Party video\"></iframe>\n          </div>\n          <div class=\"archive-ctm__text\">\nArtwork and creative direction for King Street Hotel. The concept was to create a uni frat-based party vibe with an emphasis on the specials offered on the night.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Bukez Finest</span>\n          <span class=\"archive-ctm__meta\">Brand Redesign / Music / Social Assets</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n   <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248901116332924589955545/Bukez---Bassweight_LOGO-EDITBALE-01.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861405249067137029587975920089/Default-pic.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405249048690285514266368473/Default-pic_1.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248993350053293137713625/Bukez---Bassweight_LOGO-EDITBALE-12.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2861405248974903309219428162009/Bukez---Bassweight_LOGO-EDITBALE-09.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405248956456565145718610393/Bukez---Bassweight_LOGO-EDITBALE-08.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405248938009821072009058777/Bukez---Bassweight_LOGO-EDITBALE-05.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2861405248919563076998299507161/Bukez---Bassweight_LOGO-EDITBALE-04.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n     <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405248845776100703461300697/Bukez_FB_1.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"333\"> \n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405248882669588850880403929/Bukez_Twitter.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"252\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248864222844777170852313/Bukez_FB_2.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"333\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for German Dubstep and bass music producer Bukez Finezt branding redesign. Encompassing both a logo and social media collateral.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Melbourne City Cider</span>\n          <span class=\"archive-ctm__meta\">Packaging / Label Design</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405248218586802197336545753/1_3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248292373778492174752217/2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405248310820522565884303833/3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Melbourne City Cider came to me looking to design a label for the cider release. The brief was to design something that would be striking to young upper-class business people of Melbourne, with a refined colour scheme that wasn&#x27;t hard on the eye.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Implicate Spatial Reality</span>\n          <span class=\"archive-ctm__meta\">Experimental / Motion / Editorial Feature</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__video\">\n            <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/WEDec2h62Fs\" title=\"Implicate Spatial Reality video\"></iframe>\n          </div>\n          <div class=\"archive-ctm__text\">\n            At the end of last year Its Nice That put out an open brief to think of one word which best summed up your 2017, and then incorporate your word into any form of visual. The word that I chose was “Exhausted”. I was lucky enough to have my piece shared on their blog.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Barcito</span>\n          <span class=\"archive-ctm__meta\">Hospitality / Menus / Art Direction</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405248476841219229270268377/B-1_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405248661308659966365784537/Bb-11.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405248642861915892656232921/Bb-10.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861405248624415171818946681305/Bb-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861405248605968427745237129689/Bb-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405248587521683671527578073/Bb-8_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Z2861405248569074939597818026457/Bb-6.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/W2861405248550628195524108474841/Bb-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405248532181451450398923225/Bb-4_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405248513734707376689371609/Bb-3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248495287963302979819993/Bb-2_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for Newcastle’s Barcito a Central American themed restaurant. The brief was to design menus as colourful and loud as Central America Itself.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Monxx</span>\n          <span class=\"archive-ctm__meta\">Music / Digital Illustration / Ongoing Work</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/T2861405250930258181032640633305/Screen-Shot-2018-05-04-at-9.52.04-am.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"562\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405250911811436958931081689/Screen-Shot-2018-05-04-at-9.51.34-am_2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"562\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861405250210835162157968120281/MONXX3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2861405250192388418084258568665/Monxx-skrillex_HD.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405250173941674010549017049/Monxx_Robot.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Z2861405250155494929936839465433/MONXX_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405248458394475155560716761/31275745_1812722798848540_6922642624293634048_o.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"471\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405248439947731081851165145/31166307_1797646803632739_548395151068758016_n.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"1274\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for Monxx from 2017 onwards. Work has consisted of various illustrated elements for digital use on numerous platforms.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Salty Shoes</span>\n          <span class=\"archive-ctm__meta\">Apparel / Typography</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405248366160754787012958681/13398785_496774810516778_357058138_n.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"670\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405248421500987008141613529/14240998_201556110257804_415557642_n.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"597\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405248403054242934432061913/14052273_1083935105020045_1440401450_n.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"597\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405248384607498860722510297/13402730_265226843829876_74900875_n.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"597\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405250856471204737802426841/SBT_7981_grande.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"870\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for Australian brand Salty shoes brief was to create a typographical shirt design, themed around the ocean.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">The Quiet Life</span>\n          <span class=\"archive-ctm__meta\">Illustration / Apparel</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405250985598413253769288153/the_quiet_life_break_on_through_t_white_back.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/R2861405251040938645474897943001/the_quiet_life_otherside_relaxed_snapback_white.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/B2861405251022491901401188391385/the_quiet_life_otherside_relaxed_snapback_black_grande.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861405251004045157327478839769/the_quiet_life_break_on_through_t_white.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"900\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405250856471204737802426841/SBT_7981_grande.jpg_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"870\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405250874917948811511978457/Screen-Shot-2017-05-10-at-7.18.54-PM_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"896\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861405250893364692885221530073/Screen-Shot-2017-05-10-at-7.19.07-PM_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"892\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for Quiet Life.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Hard Grime</span>\n          <span class=\"archive-ctm__meta\">Festival Branding / Custom Type / Campaign Design</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861405249233157726251361884633/HG_1_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861405249362284934767328745945/HG_7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405249343838190693619194329/HG_6_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405249325391446619909642713/HG_5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/B2861405249306944702546200091097/HG_4_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405249288497958472490539481/HG_3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2861405249270051214398780987865/HG_2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405249251604470325071436249/HG_1-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\nArtwork and creative direction for Hard Grime Fesival. The brief was pretty simple, which was to move away from the darker themed art that they had in previous years for something brighter, and more fun (with emphasis on the fun). The project consists of numerous digital elements with some print design and a custom typeface.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Argyle House 5th Birthday</span>\n          <span class=\"archive-ctm__meta\">Hospitality / Event Campaign</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n         <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861405248237033546271046097369/1_5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"704\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405248347714010713303407065/22.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__video\">\n            <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/tDcojNqRcAg\" title=\"Argyle House video\"></iframe>\n          </div>\n          <div class=\"archive-ctm__text\">\nArtwork and creative direction for Argyle’s 5th Birthday Party. The Art Direction taken was themed around key birthdays like 18th’s, 21st’s.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">NYE Street Party</span>\n          <span class=\"archive-ctm__meta\">Event Branding / Type-led Campaign</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405250247728650305387223513/N-2_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/J2861405250339962370673934981593/N-7_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2861405250321515626600225429977/N-6.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861405250303068882526515878361/N-5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861405250284622138452806326745/N-4_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2861405250266175394379096775129/N-3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__video\">\n            <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/QtlmK2JJCXQ\" title=\"NYE Street Party video\"></iframe>\n          </div>\n          <div class=\"archive-ctm__text\">\n            2016 Art direction that I worked on for The Cambridge Hotel New Years Eve Street Party. The brief was to create a fun type based design, that could be correlated throughout marketing collateral.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Northlane</span>\n          <span class=\"archive-ctm__meta\">Band Design / Art Direction Collaboration</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n         <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405250358409114747644533209/northlane_icosahedron_sweater_lg_o.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"1300\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861405250376855858821354084825/northlane_icosahedron_tank_lg_o.jpg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"1300\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Design I produced for my good friends in the band Northlane, Art Direction provided by the lead singer of the band.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Safe Events</span>\n          <span class=\"archive-ctm__meta\">Music Event Branding / Digital + Motion</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861405250598216787705868704217/Safe-1_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861405250838024460664092875225/Safe-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600