const pageContent = "<div class=\"archive-ctm\">\n  <div class=\"archive-ctm__inner\">\n\n    <div class=\"archive-ctm__head\">\n      <h1>Archive</h1>\n      <p>\nOlder branding, illustration, posters, hospitality work, music projects, and experimental pieces.\n <br />\nA broader archive of client and creative work spanning different industries, formats, and years.\n      </p>\n    </div>\n\n    <div class=\"archive-ctm__list\">\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">BBQ Boys</span>\n          <span class=\"archive-ctm__meta\">Branding / Packaging / Creative Direction</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n<div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"/images/BBQ-1.jpg\" alt=\"BBQ Boys packaging design artwork 1\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"/images/BBQ-2_1.jpg\" alt=\"BBQ Boys packaging design artwork 2\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-3_1.jpg\" alt=\"BBQ Boys packaging design artwork 3\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-4.jpg\" alt=\"BBQ Boys packaging design artwork 4\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-5_1.jpg\" alt=\"BBQ Boys packaging design artwork 5\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-6_1.jpg\" alt=\"BBQ Boys packaging design artwork 6\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-7_1.jpg\" alt=\"BBQ Boys packaging design artwork 7\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/BBQ-9.jpg\" alt=\"BBQ Boys packaging design artwork 8\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__single\">\n  <img class=\"zoomable\" src=\"/images/BBQ-8.jpg\" alt=\"BBQ Boys packaging design artwork 9\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n</div>\n          <div class=\"archive-ctm__text\">\n\nArtwork and creative direction for BBQ Boys condiments. The concept was to create a clean polished design that consisted of portraits of the business owners and reflected the Brazilian origins of the company.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">The Wanderers Co</span>\n          <span class=\"archive-ctm__meta\">Illustration / Apparel / Branding Support</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n<div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"/images/W-1_1.jpg\" alt=\"The Wanderers Co apparel illustration 1\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"/images/W-2.jpg\" alt=\"The Wanderers Co apparel illustration 2\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-3_1.jpg\" alt=\"The Wanderers Co apparel illustration 3\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-4.jpg\" alt=\"The Wanderers Co apparel illustration 4\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-5.jpg\" alt=\"The Wanderers Co apparel illustration 5\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-6_1.jpg\" alt=\"The Wanderers Co apparel illustration 6\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-7_1.jpg\" alt=\"The Wanderers Co apparel illustration 7\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"/images/W-8.jpg\" alt=\"The Wanderers Co apparel illustration 8\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for The Wanderers Co from Brisbane Australia. The brief was to create some illustrative shirt designs that fit into their branding and visual identity.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Graham Gee Photography</span>\n          <span class=\"archive-ctm__meta\">Art Direction / Photography Branding</span>\n        </summary>\n     