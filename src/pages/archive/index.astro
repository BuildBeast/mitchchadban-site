---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"archive-ctm\">\n  <div class=\"archive-ctm__inner\">\n\n    <div class=\"archive-ctm__head\">\n      <h1>Archive</h1>\n      <p>\nOlder branding, illustration, posters, hospitality work, music projects, and experimental pieces.\n <br />\nA broader archive of client and creative work spanning different industries, formats, and years.\n      </p>\n    </div>\n\n    <div class=\"archive-ctm__list\">\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">BBQ Boys</span>\n          <span class=\"archive-ctm__meta\">Branding / Packaging / Creative Direction</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n<div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861405248679755404040075336153/BBQ-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861405248698202148113784887769/BBQ-2_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405248716648892187494439385/BBQ-3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405248735095636261203991001/BBQ-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861405248753542380334913542617/BBQ-5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861405248771989124408623094233/BBQ-6_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861405248790435868482332645849/BBQ-7_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2861405248827329356629751749081/BBQ-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__single\">\n  <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405248808882612556042197465/BBQ-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n</div>\n          <div class=\"archive-ctm__text\">\n\nArtwork and creative direction for BBQ Boys condiments. The concept was to create a clean polished design that consisted of portraits of the business owners and reflected the Brazilian origins of the company.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">The Wanderers Co</span>\n          <span class=\"archive-ctm__meta\">Illustration / Apparel / Branding Support</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n<div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/J2861405251059385389548607494617/W-1_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2861405251077832133622317046233/W-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2861405251096278877696026597849/W-3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2861405251114725621769736149465/W-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405251133172365843445701081/W-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861405251151619109917155252697/W-6_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861405251170065853990864804313/W-7_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2861405251188512598064574355929/W-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for The Wanderers Co from Brisbane Australia. The brief was to create some illustrative shirt designs that fit into their branding and visual identity.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Graham Gee Photography</span>\n          <span class=\"archive-ctm__meta\">Art Direction / Photography Branding</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861405249140924005882814126553/folio1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"771\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861405249159370749956523678169/folio2_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"771\">\n  </div>\n</div>\n\n<div class=\"archive-ctm__gallery3\">\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2861405249177817494030233229785/folio3_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"612\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/W2861405249196264238103942781401/folio4_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"771\">\n  </div>\n  <div class=\"archive-ctm__gallery3Item\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2861405249214710982177652333017/folio5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"655\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for Photographer Graham Gee. The art direction was themed around mountains and photographic histograms.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Zoltan Doübious</span>\n          <span class=\"archive-ctm__meta\">Apparel Illustration</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n       <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861405248200140058123626994137/1_2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2861405248273927034418465200601/2_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Shirt design for the London-based Zoltan Doübious. The brief was to illustrate an image that reflected interconnectedness through music in an almost hieroglyphic-type style somewhat reminiscent of alien languages.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Posters</span>\n          <span class=\"archive-ctm__meta\">Event Posters / Print + Digital Campaigns</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n         <div class=\"image-gallery archive-ctm__massGallery\" gid=\"38\">\n<img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2861407206635618131645593410009/18-46.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861407206617171387571883858393/18-44.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861407206580277899424464755161/18-25.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Z2861407206598724643498174306777/18-26.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861407205879301624623501793753/16-16.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861407205953088600918340000217/16-30.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861407206395810458687369239001/17-54.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/X2861407206229789762023983274457/17-30.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2861407206063769065360597309913/16-63.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861407205694834183886406277593/15-27.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861407205916195112770920896985/16-22.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/T2861407206156002785729145067993/17-10_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/C2861407206414257202761078790617/17-61.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class