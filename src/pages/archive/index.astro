ng=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861407206506490923129626548697/18-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/J2861407206340470226466240584153/17-50.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2861407206266683250171402377689/17-36.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861407206192896273876564171225/17-25.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2861407206174449529802854619609/17-23.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861407206469597434982207445465/18-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861407206008428833139468655065/16-39.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861407205842408136476082690521/16-13.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2861407205934641856844630448601/16-26.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2861407206285129994245111929305/17-48-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/T2861407206100662553508016413145/17-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861407205823961392402373138905/16-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/T2861407206358916970539950135769/17-52-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861407205989982089065759103449/16-37.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2861407205750174416107534932441/15-54.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/R2861407205731727672033825380825/15-48.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/U2861407205657940695738987174361/15-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2861407205805514648328663587289/15-60.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2861407205621047207591568071129/15-5_1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2861407205897748368697211345369/16-20.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"><img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/P2861407205768621160181244484057/15-56.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\"></div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for event-based projects over the years. All designs consist of both print and digital marketing elements.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Pod Tings</span>\n          <span class=\"archive-ctm__meta\">Logo / Splash Screen / Motion Support</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"archive-ctm__video\">\n            <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/x8DMhesMrIU\" title=\"Pod Tings video\"></iframe>\n          </div>\n          <br />\n          <div class=\"archive-ctm__split\">\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/L2861405250469089579189901842905/PT-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n  <div class=\"archive-ctm__splitItem\">\n    <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2861405250450642835116192291289/PT-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"900\" height=\"675\">\n  </div>\n</div>\n          <div class=\"archive-ctm__text\">\n            Artwork and creative direction for a logo and splash screen for Podtings podcast and Youtube videos.\n          </div>\n        </div>\n      </details>\n\n      <details class=\"archive-ctm__item\">\n        <summary class=\"archive-ctm__summary\">\n          <span class=\"archive-ctm__title\">Logos</span>\n          <span class=\"archive-ctm__meta\">Identity Design / Various Clients</span>\n        </summary>\n        <div class=\"archive-ctm__body\">\n          <div class=\"image-gallery archive-ctm__massGallery\" gid=\"40\">\n<img class=\"zoomable\" src=