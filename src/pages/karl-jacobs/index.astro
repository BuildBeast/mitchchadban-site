---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Illustration / Apparel / Collaboration</div>\n      <h1>Karl Jacobs</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nA small apparel collection created for American Twitch streamer and YouTuber Karl Jacobs, built around playful mini golf-themed illustrations for screen-printed dark tees.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/KJ-6.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-3.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 2\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-4.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 3\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Karl Jacobs</strong> was a small apparel project centred around a mini golf theme, created for screen printing across a range of dark tees. The brief called for illustrations that felt playful, graphic, and immediately wearable, while still carrying enough character to connect with Karl Jacobs’ audience.\n        </p>\n\n        <p>\n          The creative direction focused on making the artwork feel fun, bold, and collection-ready rather than overly complex. The result was a set of illustrations designed to work cleanly in print while still feeling distinctive and tied to the concept.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Karl Jacobs</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Illustration / Apparel Graphics</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Direction</div>\n          <div class=\"portfolio-project-ctm__value\">Rish / Revolt Enterprises</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Theme</div>\n          <div class=\"portfolio-project-ctm__value\">Mini Golf / Screen Print Collection</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/KJ-5.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 4\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-2.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 5\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-1.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 6\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/yellow-billy-the-sty/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Yellow Billy &#x26; The Sty</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/johnny-bird/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Johnny Bird</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Karl Jacobs | Mitch Chadban"
  description="Karl Jacobs apparel project: mini-golf illustrations designed for screen-printed dark tees and built for a bold creator merch drop."
  canonical="https://mitchchadban.com/karl-jacobs/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/karl-jacobs/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/karl-jacobs/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/karl-jacobs/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
