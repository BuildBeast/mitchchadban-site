---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Creative Direction / Merchandise / Interior Concepts</div>\n      <h1>Yellow Billy &#x26; The Sty</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nCreative concepts, merchandising, and interior design ideas developed for Yellow Billy — a fire-driven Hunter Valley restaurant built around atmosphere, character, and cooking over flame.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-6.jpg\" alt=\"Flame shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-5.jpg\" alt=\"Skull shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-4.jpg\" alt=\"Vintage shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-3.jpg\" alt=\"Yellow Billy shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-2.jpg\" alt=\"Illustration of Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-10.jpg\" alt=\"Skull Illustration for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-9.jpg\" alt=\"Female Yellow billy Illustartion\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Yellow Billy</strong> is one of Pokolbin’s standout dining venues, known for its fire-cooked approach and strong sense of atmosphere. The project centred on developing interior design ideas and merchandising concepts that could reflect that identity in a way that felt memorable, distinctive, and true to the venue.\n        </p>\n\n        <p>\nA major part of the venue’s appeal is its custom-built fire pit, which serves as both a practical cooking tool and a strong visual centrepiece. The design direction responded to that energy by focusing on elemental, character-led concepts that tied back to the broader spirit of Yellow Billy as a brand.\n        </p>\n\n        <p>\nAcross the creative work, the goal was to create pieces that felt connected to one singular idea — Yellow Billy itself — rather than a collection of unrelated assets. The result was a body of work designed to support the venue’s interior atmosphere, merchandise direction, and overall personality.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Yellow Billy &#x26; The Sty</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Creative Direction / Merchandise / Interior Concepts</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Pokolbin, Hunter Valley</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/YB-7.jpg\" alt=\"Toastie illustration on coaster\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/YB-8.jpg\" alt=\"Toastie shirt design for the Sty\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://yellowbillyrestaurant.com\" rel=\"noopener\" target=\"_blank\">yellowbillyrestaurant.com</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/paragon-bm\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Paragon BM</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/karl-jacobs/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Karl Jacobs</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Yellow Billy & The Sty | Mitch Chadban"
  description="Creative direction, merchandise and interior concepts for Yellow Billy, a fire-cooked Hunter Valley restaurant in Pokolbin built around atmosphere and character."
  canonical="https://mitchchadban.com/yellow-billy-the-sty/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
