const pageContent = "<!--  Schema Markup — paste this block into a Custom HTML block ABOVE the page content  -->\n<script>\n[\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Service\",\n    \"name\": \"Custom Pet Portraits\",\n    \"description\": \"Hand-illustrated custom pet portraits created from your photos by designer Mitch Chadban, based in Australia. Available as digital files or print-ready artwork. All pets welcome — dogs, cats, rabbits, birds and more.\",\n    \"url\": \"https://mitchchadban.com/custom-pet-portraits/\",\n    \"provider\": {\n      \"@type\": \"Person\",\n      \"name\": \"Mitch Chadban\",\n      \"url\": \"https://mitchchadban.com\",\n      \"jobTitle\": \"Designer\",\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"addressCountry\": \"AU\"\n      }\n    },\n    \"areaServed\": {\n      \"@type\": \"Country\",\n      \"name\": \"Australia\"\n    },\n    \"serviceType\": \"Custom Illustration\",\n    \"offers\": [\n      {\n        \"@type\": \"Offer\",\n        \"name\": \"Digital Pet Portrait\",\n        \"description\": \"Custom hand-illustrated pet portrait delivered as high-res digital files — web and print-ready. Includes 1 revision.\",\n        \"price\": \"89\",\n        \"priceCurrency\": \"AUD\",\n        \"priceSpecification\": {\n          \"@type\": \"PriceSpecification\",\n          \"minPrice\": \"89\",\n          \"priceCurrency\": \"AUD\"\n        }\n      },\n      {\n        \"@type\": \"Offer\",\n        \"name\": \"Pet Portrait + Print-Ready Files\",\n        \"description\": \"Custom portrait with sized print-ready files (A4, A3, A2). Optional name or date text. Includes 1 revision.\",\n        \"price\": \"119\",\n        \"priceCurrency\": \"AUD\",\n        \"priceSpecification\": {\n          \"@type\": \"PriceSpecification\",\n          \"minPrice\": \"119\",\n          \"priceCurrency\": \"AUD\"\n        }\n      },\n      {\n        \"@type\": \"Offer\",\n        \"name\": \"Duo or Multi-Pet Portrait\",\n        \"description\": \"Two or more pets illustrated in a single balanced composition. Print-ready files included. Includes 1 revision.\",\n        \"price\": \"149\",\n        \"priceCurrency\": \"AUD\",\n        \"priceSpecification\": {\n          \"@type\": \"PriceSpecification\",\n          \"minPrice\": \"149\",\n          \"priceCurrency\": \"AUD\"\n        }\n      }\n    ]\n  },\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    \"mainEntity\": [\n      {\n        \"@type\": \"Question\",\n        \"name\": \"What animals do you illustrate?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Dogs, cats, rabbits, birds, guinea pigs — any pet with a face. If you're unsure whether your animal works, send a photo and I'll give you an honest answer before you commit.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Is the portrait hand-illustrated, or is it AI-generated?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"It's hand-illustrated — by me, using design software, reference photos, and actual creative decisions. I don't run your photo through an AI art generator or a filter. The result looks like your pet, not like a stock illustration of a dog.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Can you do more than one pet in a single portrait?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Yes. Multi-pet portraits are available under Option C. The pets don't need to be photographed together — I can composite them from separate photos into a single balanced composition.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"How long does a custom pet portrait take?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Most commissions are completed within 5–10 business days depending on the queue at the time. If you have a hard deadline — a birthday, Christmas, an anniversary — tell me upfront and I'll let you know if I can accommodate it.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Do you do memorial pet portraits?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Yes, and these are handled with particular care. If you've lost a pet and are working from limited photos, I'll tell you honestly what's achievable and work with what you have.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Can you add a name or date to the portrait?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Absolutely. Name, date, a small subtitle — whatever suits the piece. This is included in the print-ready and multi-pet options, or can be added to the digital option on request.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"What if I don't love the first draft?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Every commission includes one round of revisions. You can ask for changes to expression, markings, colours, background, or composition. If something's not right, we fix it.\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Do you ship prints?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"All commissions are delivered as digital files. I provide print-ready sizing options and can recommend Australian print services. If you want a printed and framed version organised for you, get in touch to discuss options.\"\n        }\n      }\n    ]\n  },\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Person\",\n    \"name\": \"Mitch Chadban\",\n    \"url\": \"https://mitchchadban.com\",\n    \"jobTitle\": \"Designer & Illustrator\",\n    \"description\": \"Australian designer and illustrator specialising in custom pet portraits, branding, and digital design.\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"addressCountry\": \"AU\"\n    },\n    \"knowsAbout\": [\"Custom Pet Portraits\", \"Digital Illustration\", \"Graphic Design\", \"Branding\"]\n  }\n]\n</script>\n\n<!--  SEO Metadata — add these to your WordPress SEO plugin (Yoast / RankMath)  -->\n<!-- \n  SEO Title:    Custom Pet Portraits Australia — Hand-Illustrated from Your Photos\n  Meta Desc:    Hand-illustrated custom pet portraits by Australian designer Mitch Chadban. Not AI. All pets welcome. Digital and print-ready files. From $89. Commissions open.\n -->\n\n<div class=\"mc-about\">\n\n  <h1>Custom Pet Portraits from Photos — Hand-Illustrated, Not AI</h1>\n\n  <p>\nI create custom illustrated pet portraits from your photos — clean, modern artwork you can print, frame, and actually put on your wall. Every portrait is hand-illustrated by a real designer (me, Mitch — based in Australia), not run through an AI filter. One round of revisions is included, and delivery is fast. If you want something that genuinely looks like your pet, this is how you get it.\n  </p>\n\n  <p>\nDogs, cats, rabbits, birds — if it has a face, I can illustrate it. Commissions open now.\n  </p>\n\n  <!--  Trust bar  -->\n  <p>\n✦ Hand-illustrated by a real designer  |  ✦ Based in Australia  |  ✦ Revision included  |  ✦ High-res files, print-ready\n  </p>\n\n  <h2>What You Get</h2>\n  <p>Every pet portrait commission includes:</p>\n  <ul>\n    <li>A custom-illustrated portrait based on your photos — drawn by hand, not generated by AI</li>\n    <li>One round of revisions so it feels exactly right (expression, markings, background, colours)</li>\n    <li>Final files in high-res formats — both web and print-ready</li>\n    <li>Optional background and colour treatment (minimal, bold, or clean gradient)</li>\n    <li>Optional name or date text — great for gifts and memorials</li>\n  </ul>\n\n  <div class=\"img-full-ctm\">\n    <img class=\"zoomable\" src=\"/images/Custom-Pet-Portraits-Made-From-Your-Photos-boss.png\" alt=\"Cheesy corporate stock photo of a dog sitting at a desk wearing a tie and glasses, looking extremely professional. A human hand holds up a framed illustrated pet portrait of the same dog (portrait contains only the dog image, no text). Overlit office, staged, slightly uncanny AI look, wide banner crop, no logos.\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"720\">\n  </div>\n\n  <h2>Portrait Styles — Pick Your Vibe</h2>\n\n  <h3>Style 1: Clean + Modern</h3>\n  <p>Simple, sharp lines and a premium look. Works for any pet, any home. This is the most popular option — it prints beautifully and suits everything from apartment walls to gallery frames.</p>\n\n  <h3>Style 2: Bold + Fun</h3>\n  <p>More colour and personality. Great for gifts, kids&#x27; rooms, or anyone who wants their pet to look like they belong on a magazine cover. High impact, high character.</p>\n\n  <h3>Style 3: Minimal Outline</h3>\n  <p>Super clean and classy. The most understated option — ideal for subtle wall art or a tasteful memorial piece. Fewer colours, stronger lines.</p>\n\n  <h2>How It Works</h2>\n\n  <h3>Step 1 — Send your photos</h3>\n  <p>Send 2–5 photos of your pet (phone pics are fine as long as they&#x27;re clear and well-lit). I&#x27;ll tell you which one works best if you&#x27;re unsure.</p>\n\n  <h3>Step 2 — I illustrate your pet</h3>\n  <p>I hand-illustrate the portrait and send you a preview — usually within 5–7 business days depending on the current queue. If you have a deadline (birthday, Christmas, gotcha day), tell me upfront and I&#x27;ll work around it.</p>\n\n  <h3>Step 3 — Review + tweak</h3>\n  <p>You review the draft and request small changes — expression, markings, background colour, anything that doesn&#x27;t feel quite right. One revision round is included with every commission.</p>\n\n  <h3>Step 4 — Final delivery</h3>\n  <p>You receive high-res files optimised for both digital use and professional printing. Need print sizing guidance or specific file formats? Just ask.</p>\n\n  <h2>Pricing</h2>\n\n  <h3>Option A: Digital Pet Portrait — from $89</h3>\n  <p>Perfect for printing yourself or using online (profile pics, screensavers, digital frames).</p>\n  <ul>\n    <li>1 pet</li>\n    <li>High-res digital files — web and print-ready</li>\n    <li>1 revision round</li>\n  </ul>\n\n  <h3>Option B: Pet Portrait + Print-Ready Files — from $119</h3>\n  <p>Best for gifts and wall art. Includes sized and optimised files ready to send straight to a printer.</p>\n  <ul>\n    <li>1 pet</li>\n    <li>Print-ready files with sizing options (A4, A3, A2)</li>\n    <li>Optional name or date text</li>\n    <li>1 revision round</li>\n  </ul>\n\n  <h3>Option C: Duo or Multi-Pet Portrait — from $149</h3>\n  <p>For households where one portrait just isn&#x27;t enough.</p>\n  <ul>\n    <li>2+ pets in one composition</li>\n    <li>Balanced layout and matched style across all pets</li>\n    <li>Print-ready files</li>\n    <li>1 revision round</li>\n  </ul>\n\n  <p><em>Not sure which option fits? Send your enquiry and I&#x27;ll recommend the right one.</em></p>\n\n  <h2>What Clients Say</h2>\n\n  <p>\n    <strong>&#x22;The portrait looks exactly like him — the markings, the expression, everything.&#x22;</strong><br />\n    — Sarah M., portrait of Biscuit the Golden Retriever\n  </p>\n\n  <p>\n    <strong>&#x22;I ordered it as a Christmas gift and Mitch delivered it with time to spare. The quality blew me away.&#x22;</strong><br />\n    — Tom R., duo portrait of two cats\n  </p>\n\n  <p>\n    <strong>&#x22;We got a memorial portrait after losing our dog. It was handled with real care and it&#x27;s the most meaningful thing on our wall.&#x22;</strong><br />\n    — Jess K., memorial portrait\n  </p>\n\n  <p><em>[Have a commission? Yours could be here. Every client gets asked for feedback.]</em></p>\n\n  <div class=\"img-full-ctm\">\n    <img class=\"zoomable\" src=\"/images/Custom-Pet-Portraits-Made-From-Your-Photos-approval.png\" alt=\"Awkward stock photo of three pets (dog/cat mix) sitting like a serious board meeting around a table, with printed portrait drafts scattered around (blank borders, no text). One pet has a tiny clipboard (no writing). Overly serious vibe, bright studio lighting, slightly uncanny AI, wide banner, no logos.\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"720\">\n  </div>\n\n  <h2>Perfect For</h2>\n  <ul>\n    <li>Birthday and Christmas gifts — something personal that won&#x27;t end up in a drawer</li>\n    <li>&#x22;New puppy&#x22; or &#x22;new kitten&#x22; celebrations</li>\n    <li>Memorial portraits — handled with care, delivered with attention to detail</li>\n    <li>Housewarming gifts (pet owners are a reliable market for this)</li>\n    <li>Anyone who believes their cat is objectively better than most people (correct)</li>\n  </ul>\n\n  <h2>Photo Tips — How to Get the Best Result</h2>\n  <p>The better the photo, the better the portrait. Here&#x27;s what works best:</p>\n  <ul>\n    <li><strong>Good lighting</strong> — natural light near a window is ideal. Avoid dark rooms or harsh flash</li>\n    <li><strong>Face clearly visible</strong> — eyes, nose, and any distinctive markings should be in focus</li>\n    <li><strong>Minimal motion blur</strong> — a still moment, not mid-zoomies</li>\n    <li><strong>A few angles if possible</strong> — front-on plus a 3/4 angle gives the most to work with</li>\n  </ul>\n  <p>If you only have one decent photo, send it anyway. I&#x27;ll let you know if it&#x27;ll work.</p>\n\n  <h2>Frequently Asked Questions</h2>\n\n  <h3>What animals do you illustrate?</h3>\n  <p>Dogs, cats, rabbits, birds, guinea pigs — any pet with a face. I&#x27;ll even accept a well-loved fish or a particularly characterful pet rock. If you&#x27;re unsure whether your animal works, send a photo and I&#x27;ll give you an honest answer before you commit.</p>\n\n  <h3>Is the portrait hand-illustrated, or is it AI-generated?</h3>\n  <p>It&#x27;s hand-illustrated — by me, using design software, reference photos, and actual creative decisions. I don&#x27;t run your photo through an AI art generator or a filter. That&#x27;s the whole point. The result looks like your pet, not like a stock illustration of a dog.</p>\n\n  <h3>Can you do more than one pet in a single portrait?</h3>\n  <p>Yes. Multi-pet portraits are available under Option C. The pets don&#x27;t need to be photographed together — I can composite them from separate photos into a single balanced composition. Just let me know how many pets and I&#x27;ll confirm the approach.</p>\n\n  <h3>How long does a custom pet portrait take?</h3>\n  <p>Most commissions are completed within 5–10 business days depending on the queue at the time. If you have a hard deadline — a birthday, Christmas, an anniversary — tell me upfront and I&#x27;ll let you know if I can accommodate it. I don&#x27;t overpromise on timelines.</p>\n\n  <h3>Do you do memorial portraits?</h3>\n  <p>Yes, and these are handled with particular care. If you&#x27;ve lost a pet and are working from limited photos, let me know — I&#x27;ll tell you honestly what&#x27;s achievable and work with what you have. A lot of clients say a memorial portrait is the most meaningful thing to come out of this.</p>\n\n  <h3>Can you add a name, date, or text to the portrait?</h3>\n  <p>Absolutely. Name, date, a small subtitle — whatever suits the piece. This is included in the print-ready and multi-pet options, or can be added to Option A on request.</p>\n\n  <h3>What if I don&#x27;t love the first draft?</h3>\n  <p>Every commission includes one round of revisions. You can ask for changes to expression, markings, colours, background, or composition. The goal is a portrait that genuinely looks like your pet — not a generic illustration. If something&#x27;s not right, we fix it.</p>\n\n  <h3>Do you ship prints?</h3>\n  <p>All commissions are delivered as digital files. I provide print-ready sizing options and can recommend Australian print services. If you want a printed and framed version organised for you, get in touch and we can discuss options depending on your location.</p>\n\n  <h2>Ready to Commission a Pet Portrait?</h2>\n  <p>Send an enquiry with the following and I&#x27;ll confirm the best option and next steps:</p>\n  <ul>\n    <li>Your pet&#x27;s name (and species, if not obvious)</li>\n    <li>How many pets</li>\n    <li>Your preferred style (Clean + Modern / Bold + Fun / Minimal Outline)</li>\n    <li>Your deadline, if it&#x27;s a gift</li>\n    <li>2–5 photos</li>\n  </ul>\n\n  <p>\nButton: Commission a Pet Portrait<br />\n    <small>Prefer email? Contact Mitch</small>\n  </p>\n<br />\n  <br />\n</div>";
