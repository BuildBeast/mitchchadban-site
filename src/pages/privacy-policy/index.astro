---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"mc-about\">\n\n  <h1>Privacy Policy</h1>\n  <p><b>Last updated:</b> 22 February 2026</p>\n\n  <p>\nThis Privacy Policy explains how MitchChadban.com (“we”, “us”, “our”) collects, uses, and protects information when you visit\n    mitchchadban.com (the “Site”).\n  </p>\n\n  <h2>What we collect</h2>\n  <p>We keep this simple. We collect limited information in the following ways:</p>\n\n  <h3>1) Website analytics (Google Analytics)</h3>\n  <p>\nWe use Google Analytics to understand how visitors use the Site (e.g. pages viewed, time on site, general location, device/browser type). This data is collected using cookies and similar technologies.\n  </p>\n  <p>\nWe do <b>not</b> use Google Analytics to intentionally collect sensitive personal information.\n  </p>\n\n  <h3>2) Information you choose to share</h3>\n  <p>\nIf you contact us using the Site’s contact form, we collect the information you provide (such as your name and message details) so we can respond.\n  </p>\n\n  <h2>How we use your information</h2>\n  <p>We use information to:</p>\n  <ul>\n    <li>operate and improve the Site</li>\n    <li>understand what content and pages are useful</li>\n    <li>respond to enquiries submitted via the Site</li>\n    <li>maintain the security of the Site</li>\n  </ul>\n\n  <h2>Cookies</h2>\n  <p>\nCookies are small files stored on your device. We use cookies and similar technologies for analytics and basic site functionality.\n  </p>\n  <p>\nYou can control cookies through your browser settings. You can also opt out of Google Analytics using Google’s opt-out browser add-on\n (available from Google).\n  </p>\n\n  <h2>Sharing your information</h2>\n  <p><b>We do not sell personal information.</b></p>\n  <p>\nWe may share information with trusted service providers that help us operate the Site (for example, analytics and hosting providers).\n These providers may process information on our behalf and are expected to handle it securely.\n  </p>\n\n  <h2>International data processing</h2>\n  <p>\nSome service providers (including Google) may process data outside Australia. Where this occurs, we take reasonable steps to ensure\n information is handled in line with this policy.\n  </p>\n\n  <h2>Data security</h2>\n  <p>\nWe take reasonable steps to protect information. No method of transmission or storage is completely secure, so we can’t guarantee absolute security.\n  </p>\n\n  <h2>Access, correction, and deletion</h2>\n  <p>\nIf you want to request access to, correction of, or deletion of personal information we hold about you, contact us via the Site’s contact form: <a href=\"mailto:mitch.chadban@hotmail.com\" >https://mitchchadban.com/contact</a> (or your actual contact page URL)\n  </p>\n\n  <h2>Contact</h2>\n  <p>\nFor questions about this Privacy Policy, contact us via: <a href=\"mailto:mitch.chadban@hotmail.com\" >https://mitchchadban.com/contact</a>\n  </p>\n<br />\n  <br />\n</div>";
---

<BaseLayout
  title="Privacy Policy | Mitch Chadban"
  description="How mitchchadban.com collects, uses and protects your information, including analytics, cookies, data sharing and your privacy rights."
  canonical="https://mitchchadban.com/privacy-policy/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/privacy-policy/' },
    { lang: 'es', href: 'https://mitchchadban.com/politica-de-privacidad/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/privacy-policy/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
