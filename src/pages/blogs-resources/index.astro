const pageContent = "<!--  BLOG ARCHIVE (MATCH SELECTED WORK HEAD SPACING)  -->\n<section class=\"blog-ctm portfolio-ctm\" id=\"blogArchive\">\n  <div class=\"portfolio-ctm__inner\" style=\"padding-top:72px;\">\n\n    <div class=\"blog-ctm__head portfolio-ctm__head\" style=\"margin-top:0;\">\n      <h1 style=\"margin:0 0 18px; font-size:clamp(78px,10vw,132px); line-height:0.9;\">Blog Archive</h1>\n      <p class=\"blog-ctm__sub\" style=\"margin:0;\">Pick a topic. Find the playbook. Ship faster.</p>\n    </div>\n\n    <div aria-label=\"Blog filters\" class=\"blog-ctm__controls\">\n      <div aria-label=\"Filter by tag\" class=\"blog-ctm__tags\" id=\"blogTags\">\n        <button class=\"blog-ctm__tagbtn is-active\" data-tag=\"All\" type=\"button\">All</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"AEO\" type=\"button\">AEO</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"AI\" type=\"button\">AI</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Australia\" type=\"button\">Australia</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"B2B SaaS\" type=\"button\">B2B SaaS</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Branding\" type=\"button\">Branding</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Checklist\" type=\"button\">Checklist</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Conversions\" type=\"button\">Conversions</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Demand Gen\" type=\"button\">Demand Gen</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Design\" type=\"button\">Design</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Engaging\" type=\"button\">Engaging</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Funnel\" type=\"button\">Funnel</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Growth Marketing\" type=\"button\">Growth Marketing</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"How to\" type=\"button\">How to</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Lead\" type=\"button\">Lead</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Marketing\" type=\"button\">Marketing</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Messaging\" type=\"button\">Messaging</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Positioning\" type=\"button\">Positioning</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"SaaS\" type=\"button\">SaaS</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"SEO\" type=\"button\">SEO</button>\n        <button class=\"blog-ctm__tagbtn\" data-tag=\"Social Media\" type=\"button\">Social Media</button>\n      </div>\n    </div>\n\n    <div class=\"blog-ctm__list\" id=\"blogList\">\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Best SEO + AI Workflow for 2026</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">AI</span><span class=\"post-ctm__pill\">2026</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical, step-by-step playbook for doing SEO with AI in 2026—without publishing generic “AI-sounding” content. 8-stage workflow + prompts + editorial rules.</p>\n        <a class=\"post-ctm__link\" href=\"/best-seo-and-ai-workflow-for-2026/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">AEO Australia: How to Show Up in AI Answers</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">AEO</span><span class=\"post-ctm__pill\">AI</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical AEO playbook for Australia + Spain: citations in AI answers (ChatGPT, AI Overviews, Perplexity), multilingual setup, templates, and rollout plan.</p>\n        <a class=\"post-ctm__link\" href=\"/aeo-australia-how-to-show-up-in-ai-answers/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">SEO for SaaS Australia: What Works in 2026</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">SaaS</span><span class=\"post-ctm__pill\">2026</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical SEO playbook for AU SaaS teams in 2026—focused on demos and pipeline. Money pages, clusters, trust signals, technical SEO, distribution + 30/60/90.</p>\n        <a class=\"post-ctm__link\" href=\"/seo-for-saas-australia-what-works-in-2026/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Growth Marketing Strategy for SaaS</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Marketing</span><span class=\"post-ctm__pill\">SaaS</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A simple growth marketing system for SaaS teams: one clear goal, sane experiments, weekly cadence, and the few metrics that matter—plus a 30/60/90 plan.</p>\n        <a class=\"post-ctm__link\" href=\"/growth-marketing-strategy-for-saas/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Logo Design Cost in Australia: What You Actually Get</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Branding</span><span class=\"post-ctm__pill\">Design</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">Australia-specific logo pricing: what you get at each tier, deliverables, hidden costs, licensing/trademark notes, and questions to avoid paying twice.</p>\n        <a class=\"post-ctm__link\" href=\"/logo-design-cost-in-australia-what-you-actually-get/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Canva vs Designer: When DIY Starts Costing You</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Branding</span><span class=\"post-ctm__pill\">Design</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A quick reality check on Canva vs hiring a designer—showing the point where DIY starts costing you leads, trust, and time (and what to do instead).</p>\n        <a class=\"post-ctm__link\" href=\"/canva-vs-designer-when-diy-starts-costing-you/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">The Marketing Collateral Checklist: What Every Business Actually Needs</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Branding</span><span class=\"post-ctm__pill\">Design</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A simple checklist of the marketing collateral every business needs—what to prioritise first, and what to skip.</p>\n        <a class=\"post-ctm__link\" href=\"/the-marketing-collateral-checklist-what-you-need/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">How to Choose the Right Freelancer vs Agency (Cost, Speed, Quality)</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Branding</span><span class=\"post-ctm__pill\">Design</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical guide to choosing freelancer vs agency—based on cost, speed, quality, and what your project actually needs.</p>\n        <a class=\"post-ctm__link\" href=\"/how-to-choose-the-right-freelancer-vs-agency/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">AI SEO vs Traditional SEO: What&#x27;s Changed? (and What Still Works?)</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">AI</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical breakdown of what AI changed in SEO—and what still works—so you can stay visible and get results.</p>\n        <a class=\"post-ctm__link\" href=\"/ai-seo-vs-traditional-seo-whats-changed/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">AEO Explained: How to Rank in AI Answers</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">AEO</span><span class=\"post-ctm__pill\">AI</span><span class=\"post-ctm__pill\">How to</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A plain-English guide to AEO that shows how to structure content and build credibility so you can get featured (and cited) in AI answers across ChatGPT, Gemini, and Perplexity.</p>\n        <a class=\"post-ctm__link\" href=\"/aeo-explained-how-to-rank-in-ai-answers/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Social Media Design That Doesn’t Look Like Everyone Else</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Social Media</span><span class=\"post-ctm__pill\">Engaging</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A practical guide to creating scroll-stopping social posts with a repeatable design system, so your content looks instantly recognisable instead of templated.</p>\n        <a class=\"post-ctm__link\" href=\"/social-media-design-that-doesnt-look-like-everyone-else/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Best Growth Marketing Channels for 2026 (Australia)</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Growth Marketing</span><span class=\"post-ctm__pill\">SaaS</span><span class=\"post-ctm__pill\">Conversions</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">The 2026 Australia channel playbook for growth—where to spend your time for immediate pipeline, long-term demand, and better conversions.</p>\n        <a class=\"post-ctm__link\" href=\"/best-growth-marketing-channels-for-2026-australia/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Best Ways to Build E-E-A-T in 2026</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Marketing</span><span class=\"post-ctm__pill\">SaaS</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A breakdown of how to build E-E-A-T in 2026 using real proof, original assets, and authority signals that make your brand harder to ignore (and easier to trust).</p>\n        <a class=\"post-ctm__link\" href=\"/best-ways-to-build-e-e-a-t-in-2026/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Best Demand Gen Content for 2026</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Demand Gen</span><span class=\"post-ctm__pill\">Marketing</span><span class=\"post-ctm__pill\">Lead</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A clear content menu for 2026 that shows what to publish to create demand, capture buyer intent, and turn attention into qualified leads.</p>\n        <a class=\"post-ctm__link\" href=\"/best-demand-gen-content-for-2026/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Positioning vs Messaging: Why Your Ads Aren’t Working</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Messaging</span><span class=\"post-ctm__pill\">Positioning</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A straight explanation of positioning vs messaging, why targeting can’t save vague offers, and how to build a messaging framework that makes ads convert.</p>\n        <a class=\"post-ctm__link\" href=\"/positioning-vs-messaging-why-your-ads-arent-working/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">From Traffic to Demos: A Practical Funnel for B2B SaaS</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Funnel</span><span class=\"post-ctm__pill\">Marketing</span><span class=\"post-ctm__pill\">B2B SaaS</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A step-by-step B2B SaaS funnel that turns traffic into booked demos, with benchmark ranges to spot leaks and fix the stage that’s costing you meetings.</p>\n        <a class=\"post-ctm__link\" href=\"/from-traffic-to-demos-a-practical-funnel-for-b2b-saas/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">The 12-Point Brand Consistency Checklist</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">Branding</span><span class=\"post-ctm__pill\">Design</span><span class=\"post-ctm__pill\">Checklist</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A simple 12-point checklist to tighten your brand across every touchpoint so it looks consistent, intentional, and instantly recognisable.</p>\n        <a class=\"post-ctm__link\" href=\"/the-12-point-brand-consistency-checklist/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n\n      <article class=\"post-ctm c2-card\">\n        <div class=\"post-ctm__top\">\n          <h2 class=\"post-ctm__h\">Technical SEO Checklist (Plain English)</h2>\n          <div class=\"post-ctm__meta\">\n            <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">Checklist</span><span class=\"post-ctm__pill\">Australia</span>\n          </div>\n        </div>\n        <p class=\"post-ctm__p\">A plain-English technical SEO checklist to improve speed, indexing, and site health—so your pages can rank without hidden technical blockers.</p>\n        <a class=\"post-ctm__link\" href=\"/technical-seo-checklist-plain-english/\" >\n          <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n        </a>\n      </article>\n      <article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">SEO for Professional Services in Australia: What’s Different About Ranking When You Sell Expertise</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">Australia</span><span class=\"post-ctm__pill\">Conversions</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">Why SEO works differently when you sell expertise instead of products—covering trust, proof, buyer confidence, and what actually drives rankings and enquiries in Australia.</p>\n  <a class=\"post-ctm__link\" href=\"/seo-for-professional-services-in-australia-whats-different-about-ranking-when-you-sell-expertise/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n  </a>\n</article>\n\n<article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">How to Brief an SEO Consultant (And Actually Get Results)</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">How to</span><span class=\"post-ctm__pill\">Australia</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">A practical guide to briefing an SEO consultant properly, so you get clarity, useful priorities, and commercial results instead of vague activity and bloated reports.</p>\n  <a class=\"post-ctm__link\" href=\"/how-to-brief-an-seo-consultant/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n  </a>\n</article>\n\n<article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">Why You’re Stuck on Page 2: The 5 SEO Problems Keeping Good Pages Off Page 1</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">Conversions</span><span class=\"post-ctm__pill\">How to</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">A diagnosis-first guide to the real reasons good pages stall on page 2—and what to fix when Google finds your page relevant, but not convincing enough to rank higher.</p>\n  <a class=\"post-ctm__link\" href=\"/why-youre-stuck-on-page-2-the-5-seo-problems-keeping-good-pages-off-page-1/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n  </a>\n</article>\n\n<article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">The SEO Audit Checklist Australian Businesses Actually Need</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">Checklist</span><span class=\"post-ctm__pill\">Australia</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">A simpler, more useful SEO audit checklist for Australian businesses—focused on what is actually blocking traffic, rankings, and enquiries, not agency theatre.</p>\n  <a class=\"post-ctm__link\" href=\"/the-seo-audit-checklist-australian-businesses-actually-need/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n  </a>\n</article>\n\n<article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">What to Do When Your Google Rankings Drop Suddenly</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">How to</span><span class=\"post-ctm__pill\">Australia</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">A practical triage framework for sudden ranking drops—how to tell if the drop is real, isolate likely causes, prioritise fixes, and know when to bring in help.</p>\n  <a class=\"post-ctm__link\" href=\"/what-to-do-when-your-google-rankings-drop-suddenly/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>\n  </a>\n</article>\n\n<article class=\"post-ctm c2-card\">\n  <div class=\"post-ctm__top\">\n    <h2 class=\"post-ctm__h\">How Long Does SEO Take? (Honest Answer for Australian Businesses)</h2>\n    <div class=\"post-ctm__meta\">\n      <span class=\"post-ctm__pill\">SEO</span><span class=\"post-ctm__pill\">Australia</span><span class=\"post-ctm__pill\">How to</span>\n    </div>\n  </div>\n  <p class=\"post-ctm__p\">An honest breakdown of SEO timelines for Australian businesses—when to expect early movement, meaningful results, and what usually slows progress down.</p>\n  <a class=\"post-ctm__link\" href=\"/how-long-does-seo-take-an-honest-answer-for-australian-businesses/\" >\n    <span class=\"post-ctm__read\">Read more</span><span class=\"post-ctm__arrow\">↗</span>