---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<!--  SCHEMA  -->\n<!--  script>\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Service\",\n      \"name\": \"Design, Marketing & SEO Services\",\n      \"provider\": {\n        \"@type\": \"Person\",\n        \"name\": \"Mitch Chadban\",\n        \"url\": \"https://mitchchadban.com\"\n      },\n      \"areaServed\": {\n        \"@type\": \"Country\",\n        \"name\": \"Australia\"\n      },\n      \"hasOfferCatalog\": {\n        \"@type\": \"OfferCatalog\",\n        \"name\": \"Services & Packages\",\n        \"itemListElement\": [\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Logo Design\",\n              \"description\": \"Professional logo design from $400 (simple) to $1,200 (full professional handover with vector files, variations, and usage rules).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Brand Identity\",\n              \"description\": \"Full brand identity system from $1,800 (mini brand system) to $5,000+ (full brand identity with strategy and rollout).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"SEO Services\",\n              \"description\": \"SEO services from $790 (technical audit) to $1,500/month (ongoing monthly SEO support focused on pipeline metrics).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Marketing Services\",\n              \"description\": \"Marketing services including 90-day growth plans from $990, messaging workshops from $1,490, and monthly marketing support from $1,500/month.\"\n            }\n          }\n        ]\n      }\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How do I know which service I need?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Tell me your goal — more leads, more demos, better brand consistency, better rankings — and your timeline. I will recommend the best starting package and what to do next.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Do you do custom quotes?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes. Anything marked From depends on scope and how many assets or pages you need. Request a quote and include your brief — I will come back with a clear price.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What is the difference between the $400 logo and the $1,200 logo?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"The $400 Simple Logo is one concept with a single PNG file and no system. The $1,200 Logo Design includes multiple concepts, revisions, logo variations (primary, stacked, icon-only), colour versions, and a professional file handover including SVG and PDF.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Do you offer monthly retainers?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes — for design, marketing, SEO, or a hybrid mix. If you need consistent output, monthly support is usually the most cost-effective way to work together. Ask about hybrid packages.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How fast can you start?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Usually within a week depending on workload. If you have a deadline, include it when you request a quote.\"\n          }\n        }\n      ]\n    }\n  ]\n}\n</script -->\n\n<style>\n  /* ── Service block layout ────────────────────────────────── */\n  .mc-pricing {\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .mc-pricing h1 {\n    margin-bottom: 0.5rem;\n  }\n\n  .mc-pricing .mc-intro {\n    margin-bottom: 2rem;\n    line-height: 1.6;\n  }\n\n  /* ── Accordion ───────────────────────────────────────────── */\n  .pricing-acc {\n    border-top: 1px solid #e2e2e2;\n    margin: 2rem 0;\n  }\n\n  .pricing-acc__item {\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .pricing-acc__sum {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 1.25rem 0;\n    font-size: 1.1rem;\n    font-weight: 700;\n    cursor: pointer;\n    list-style: none;\n    user-select: none;\n  }\n\n  .pricing-acc__sum::-webkit-details-marker { display: none; }\n\n  .pricing-acc__sum::after {\n    content: &#x27;+&#x27;;\n    font-size: 1.4rem;\n    font-weight: 300;\n    line-height: 1;\n  }\n\n  .pricing-acc__item[open] &#x3E; .pricing-acc__sum::after {\n    content: &#x27;−&#x27;;\n  }\n\n  .pricing-acc__body {\n    padding: 0.5rem 0 2rem;\n  }\n\n  /* ── Service blocks ──────────────────────────────────────── */\n  .mc-service {\n    margin-bottom: 2.5rem;\n    padding-bottom: 2.5rem;\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .mc-service:last-child {\n    margin-bottom: 0;\n    padding-bottom: 0;\n    border-bottom: none;\n  }\n\n  .mc-service h3 {\n    margin: 0 0 0.25rem;\n  }\n\n  .mc-service__price {\n    font-weight: 600;\n    margin: 0 0 0.5rem;\n  }\n\n  .mc-service__desc {\n    margin: 0 0 1rem;\n    line-height: 1.6;\n  }\n\n  .mc-service__label {\n    font-weight: 700;\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin: 1rem 0 0.4rem;\n  }\n\n  .mc-service ul {\n    margin: 0 0 0.75rem;\n    padding-left: 1.25rem;\n  }\n\n  .mc-service ul li {\n    margin-bottom: 0.3rem;\n    line-height: 1.5;\n  }\n\n  .mc-service__bestfor {\n    font-size: 0.9rem;\n    margin: 0.75rem 0 0;\n  }\n\n  /* ── Shortcut section ────────────────────────────────────── */\n  .mc-shortcut {\n    background: #f7f7f7;\n    border-radius: 6px;\n    padding: 2rem;\n    margin: 2rem 0;\n  }\n\n  .mc-shortcut h2 {\n    margin: 0 0 1rem;\n  }\n\n  .mc-shortcut ul {\n    margin: 0 0 1.5rem;\n    padding-left: 1.25rem;\n  }\n\n  .mc-shortcut ul li {\n    margin-bottom: 0.5rem;\n    line-height: 1.5;\n  }\n\n  /* ── FAQ ─────────────────────────────────────────────────── */\n  .mc-faq {\n    margin: 2.5rem 0;\n  }\n\n  .mc-faq h2 {\n    margin-bottom: 1.5rem;\n  }\n\n  .mc-faq__item {\n    margin-bottom: 1.5rem;\n    padding-bottom: 1.5rem;\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .mc-faq__item:last-child {\n    border-bottom: none;\n  }\n\n  .mc-faq__item h3 {\n    margin: 0 0 0.5rem;\n  }\n\n  .mc-faq__item p {\n    margin: 0;\n    line-height: 1.6;\n  }\n\n  /* ── CTA button spacing ──────────────────────────────────── */\n  .mc-pricing .custom-btn {\n    margin-top: 0.5rem;\n  }\n</style>\n\n\n<div class=\"mc-pricing\">\n\n  <h1>Pricing and Packages</h1>\n\n  <p class=\"mc-intro\">\nPick the service you need. Get clear deliverables. Move fast.<br />\nNot sure what to choose? Request a quote, and I&#x27;ll recommend the best-fit package based on your goal, timeline, and where you&#x27;re at.\n  </p>\n\n  <a href=\"mailto:mitch.chadban@hotmail.com\" >\n    <div class=\"custom-btn\"><b>Request a quote</b></div>\n  </a>\n\n  <!--  ── ACCORDION ───────────────────────────────────────  -->\n  <div class=\"pricing-acc\">\n\n    <!--  Illustration  -->\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">Illustration</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Custom Illustration (Single Piece)</h3>\n          <p class=\"mc-service__price\">From $450 AUD</p>\n          <p class=\"mc-service__desc\">One custom illustration for web, socials, print, or product use.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>1 concept direction</li>\n            <li>1 revision round</li>\n            <li>Final files (PNG + SVG/PDF depending on style)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> hero graphics, blog headers, campaign visuals</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Illustration Pack (3–5 Pieces)</h3>\n          <p class=\"mc-service__price\">From $1,200 AUD</p>\n          <p class=\"mc-service__desc\">A set of illustrations designed to work together as a consistent system.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Style alignment (so they match)</li>\n            <li>3–5 illustrations</li>\n            <li>2 revision rounds</li>\n            <li>Export pack for web/social</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> landing pages, content series, brand visuals</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Monthly Illustration Support</h3>\n          <p class=\"mc-service__price\">From $900 AUD / month</p>\n          <p class=\"mc-service__desc\">Ongoing illustration output with a simple monthly priority queue.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Monthly planning</li>\n            <li>Priority queue</li>\n            <li>2–6 illustrations/month depending on complexity</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <!--  Design  -->\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">Design</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Social Template Pack (Core 5)</h3>\n          <p class=\"mc-service__price\">$990 AUD</p>\n          <p class=\"mc-service__desc\">A template system that looks like <em>you</em>, not a generic Canva pack.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>5 templates: value, carousel, proof, comparison, offer</li>\n            <li>Typography + spacing rules baked in</li>\n            <li>Delivered in Canva (or Figma on request)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> consistent posting without reinventing design weekly</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Marketing Collateral Pack</h3>\n          <p class=\"mc-service__price\">From $1,500 AUD</p>\n          <p class=\"mc-service__desc\">Your core sales + marketing assets designed to convert.</p>\n          <p class=\"mc-service__label\">Typical inclusions</p>\n          <ul>\n            <li>One-pager / capability statement</li>\n            <li>Slide deck template</li>\n            <li>Case study template</li>\n            <li>Proposal template</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> service businesses + B2B teams selling higher-ticket offers</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Landing Page Design (Conversion-first)</h3>\n          <p class=\"mc-service__price\">From $1,800 AUD</p>\n          <p class=\"mc-service__desc\">A landing page layout built for clarity, proof, and conversions.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Wireframe + final design</li>\n            <li>Mobile layout</li>\n            <li>Dev handoff notes (or build option)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> ads, lead magnets, service offers, launches</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Monthly Design Support</h3>\n          <p class=\"mc-service__price\">From $1,200 AUD / month</p>\n          <p class=\"mc-service__desc\">Consistent design output without hiring in-house.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Monthly priorities + delivery cadence</li>\n            <li>Social + ad creative</li>\n            <li>Collateral updates</li>\n            <li>Brand consistency checks</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <!--  Branding  -->\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">Branding</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Simple Logo (No Assets)</h3>\n          <p class=\"mc-service__price\">$400 AUD</p>\n          <p class=\"mc-service__desc\">A basic logo concept for quick use — no file suite or brand system.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>1 concept</li>\n            <li>1 revision round</li>\n            <li>1 final logo file (PNG)</li>\n          </ul>\n          <p class=\"mc-service__label\">Does not include</p>\n          <ul>\n            <li>Logo variations (stacked/icon)</li>\n            <li>Vector files (SVG/AI/EPS)</li>\n            <li>Colour versions</li>\n            <li>Guidelines or templates</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> early-stage projects that just need something simple</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Logo Design (Professional Handover)</h3>\n          <p class=\"mc-service__price\">$1,200 AUD</p>\n          <p class=\"mc-service__desc\">A clean logo system that works across web, social, and print.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>2–3 concepts</li>\n            <li>2 revision rounds</li>\n            <li>Primary + stacked + icon</li>\n            <li>Colour versions (full/black/white)</li>\n            <li>Files: SVG, PNG, PDF (AI/EPS on request)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> businesses that want credibility + correct files</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Mini Brand System (Fast Consistency Upgrade)</h3>\n          <p class=\"mc-service__price\">$1,800 AUD</p>\n          <p class=\"mc-service__desc\">Stop looking random across socials, your site, and documents.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Colour + typography system</li>\n            <li>Spacing/layout rules</li>\n            <li>Photo/style direction</li>\n            <li>Mini brand guide (PDF)</li>\n            <li>Starter templates (social or doc set)</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Brand Refresh (Existing Brand, Improved)</h3>\n          <p class=\"mc-service__price\">From $2,500 AUD</p>\n          <p class=\"mc-service__desc\">Keep your brand recognisable — make it more premium and consistent.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Refined palette + typography</li>\n            <li>Updated logo usage (if needed)</li>\n            <li>Refreshed templates</li>\n            <li>Updated guidelines</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Full Brand Identity (Strategy + System)</h3>\n          <p class=\"mc-service__price\">From $5,000 AUD</p>\n          <p class=\"mc-service__desc\">For rebrands or brands scaling into bigger markets.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Discovery + direction</li>\n            <li>Identity system (logo, colour, typography, visuals)</li>\n            <li>Guidelines</li>\n            <li>Rollout templates (social + deck + docs)</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <!--  Marketing  -->\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">Marketing</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Growth Plan (90-day)</h3>\n          <p class=\"mc-service__price\">$990 AUD</p>\n          <p class=\"mc-service__desc\">A focused plan: what to do next and what to ignore.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>60–90 min working session</li>\n            <li>Channel + funnel review</li>\n            <li>90-day roadmap (weekly actions)</li>\n            <li>KPI scoreboard</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Messaging Workshop (Positioning → Ads That Convert)</h3>\n          <p class=\"mc-service__price\">$1,490 AUD</p>\n          <p class=\"mc-service__desc\">Fix the &#x22;targeting is fine but ads aren&#x27;t converting&#x22; problem.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>ICP + category clarity</li>\n            <li>Differentiators + proof points</li>\n            <li>Messaging framework (hooks, angles, value props)</li>\n            <li>Ad angle pack (10–15 angles)</li>\n            <li>Landing page hero copy outline</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Funnel Mapping (Traffic → Leads → Demos)</h3>\n          <p class=\"mc-service__price\">$790 AUD</p>\n          <p class=\"mc-service__desc\">Find the bottleneck that&#x27;s costing you leads and booked meetings.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Funnel review + leak analysis</li>\n            <li>Benchmark comparison</li>\n            <li>Priority fixes list</li>\n            <li>Quick conversion wins</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Monthly Marketing Support</h3>\n          <p class=\"mc-service__price\">From $1,500 AUD / month</p>\n          <p class=\"mc-service__desc\">Execution support tied to pipeline outcomes.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Monthly planning</li>\n            <li>Campaign builds</li>\n            <li>Reporting focused on leads + conversion</li>\n            <li>Creative/copy coordination (as needed)</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <!--  SEO  -->\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">SEO</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Technical SEO Audit (Plain English)</h3>\n          <p class=\"mc-service__price\">$790 AUD</p>\n          <p class=\"mc-service__desc\">Speed, indexing, duplication, site health — the stuff that blocks rankings.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Search Console + crawl review</li>\n            <li>Core Web Vitals priorities</li>\n            <li>Indexation + canonical checks</li>\n            <li>Dev-ready action plan</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>SEO + AEO Audit (Search + AI Answers)</h3>\n          <p class=\"mc-service__price\">$1,290 AUD</p>\n          <p class=\"mc-service__desc\">Make your site easier to rank <em>and</em> easier to be cited in AI answers.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Technical + structure review</li>\n            <li>Extractable content fixes (summaries/FAQs/tables)</li>\n            <li>E-E-A-T/proof gaps</li>\n            <li>30/60/90 rollout plan</li>\n          </ul>\n          <p class=\"mc-service__label\">Does not include</p>\n          <ul>\n            <li>Content writing or page builds</li>\n            <li>Ongoing monitoring or implementation</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Best for:</strong> sites already getting traffic that want to appear in AI answer engines</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Buyer-Intent SEO Build (Money Pages)</h3>\n          <p class=\"mc-service__price\">From $2,500 AUD</p>\n          <p class=\"mc-service__desc\">Build the pages that drive enquiries: comparisons, alternatives, services, integrations.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Buyer-intent keyword map</li>\n            <li>Page briefs + internal link plan</li>\n            <li>On-page SEO</li>\n            <li>Publishing support (optional)</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Monthly SEO Support</h3>\n          <p class=\"mc-service__price\">From $1,500 AUD / month</p>\n          <p class=\"mc-service__desc\">Compounding growth from search tied to leads, not vanity traffic.</p>\n          <p class=\"mc-service__label\">Includes</p>\n          <ul>\n            <li>Content roadmap + briefs</li>\n            <li>On-page improvements</li>\n            <li>Internal linking</li>\n            <li>Technical hygiene checks</li>\n            <li>Conversion-focused reporting</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n  </div><!--  end .pricing-acc  -->\n\n\n  <!--  ── SHORTCUT SECTION ────────────────────────────────  -->\n  <div class=\"mc-shortcut\">\n    <h2>Not sure what to choose?</h2>\n    <ul>\n      <li>Want to look consistent fast? → <strong>Mini Brand System</strong></li>\n      <li>Need social content that looks premium? → <strong>Social Template Pack</strong></li>\n      <li>Ads getting clicks but no leads? → <strong>Messaging Workshop</strong></li>\n      <li>Traffic but no demos? → <strong>Funnel Mapping</strong></li>\n      <li>Site not ranking? → <strong>Technical SEO Audit</strong></li>\n      <li>Want search + AI answer visibility? → <strong>SEO + AEO Audit</strong></li>\n      <li>Need ongoing output across design, marketing, or SEO? → <strong>Monthly retainer — ask me about a hybrid package</strong></li>\n    </ul>\n    <a href=\"mailto:mitch.chadban@hotmail.com\" >\n      <div class=\"custom-btn\"><b>Request a quote</b></div>\n    </a>\n  </div>\n\n\n  <!--  ── FAQ ────────────────────────────────────────────  -->\n  <div class=\"mc-faq\">\n    <h2>FAQ: Pricing and Packages</h2>\n\n    <div class=\"mc-faq__item\">\n      <h3>How do I know which service I need?</h3>\n      <p>Tell me your goal (more leads, more demos, better brand consistency, better rankings) and your timeline. I&#x27;ll recommend the best starting package and what to do next.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>Do you do custom quotes?</h3>\n      <p>Yes. Anything marked &#x22;From&#x22; depends on scope and how many assets or pages you need.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>What&#x27;s the difference between the $400 logo and the $1,200 logo?</h3>\n      <p>The $400 Simple Logo is one concept with a single PNG file and no system. The $1,200 Logo Design includes multiple concepts, revisions, logo variations, and a professional file handover including SVG and PDF.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>Can I still use Canva after you build templates?</h3>\n      <p>Yes — that&#x27;s the point. Templates and rules give you speed without your brand drifting.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>Do you offer monthly retainers?</h3>\n      <p>Yes — for design, marketing, SEO, or a hybrid mix. If you need consistent output, monthly support is usually the most cost-effective way to work together.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>How fast can you start?</h3>\n      <p>Usually within a week depending on workload. If you have a deadline, include it when you request a quote.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>What do you need from me to begin?</h3>\n      <p>A link to your site, your socials if relevant, examples you like, and a short note on your target customer and what success looks like.</p>\n    </div>\n\n  </div><!--  end .mc-faq  -->\n\n\n  <!--  ── FINAL CTA ───────────────────────────────────────  -->\n  <a href=\"mailto:mitch.chadban@hotmail.com\" >\n    <div class=\"custom-btn\"><b>Request a quote</b></div>\n  </a>\n<br />\n<br />\n</div><!--  end .mc-pricing  -->";
---

