const pageContent = "<!--  SCHEMA  -->\n<!-- <script>\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Article\",\n      \"@id\": \"https://mitchchadban.com/Technical-SEO-Checklist-Plain-English#article\",\n      \"headline\": \"Technical SEO Checklist (Plain English): Speed, Indexing & Site Health\",\n      \"description\": \"A practical technical SEO checklist for 2026 covering Core Web Vitals, crawl and index control, and site health. Written in plain English for founders and marketers who need to manage technical SEO without a developer.\",\n      \"image\": \"https://mitchchadban.com/path-to-hero-image.jpg\",\n      \"datePublished\": \"2025-11-01\",\n      \"dateModified\": \"2026-04-05\",\n      \"author\": {\n        \"@type\": \"Person\",\n        \"name\": \"Mitch Chadban\",\n        \"url\": \"https://mitchchadban.com/about\",\n        \"jobTitle\": \"SEO & Marketing Specialist\",\n        \"sameAs\": [\"https://www.linkedin.com/in/mitchchadban\"]\n      },\n      \"publisher\": {\n        \"@type\": \"Person\",\n        \"name\": \"Mitch Chadban\",\n        \"url\": \"https://mitchchadban.com\"\n      },\n      \"mainEntityOfPage\": {\n        \"@type\": \"WebPage\",\n        \"@id\": \"https://mitchchadban.com/Technical-SEO-Checklist-Plain-English\"\n      }\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What is a technical SEO checklist?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"A technical SEO checklist is a structured set of checks that confirm your website can be crawled by search engines, indexed correctly, and served fast enough to meet performance standards. It covers three core areas: speed (Core Web Vitals), indexing (crawl access, sitemaps, canonicals), and site health (errors, redirects, duplication, and HTTPS). Completing a technical SEO checklist identifies blockers that prevent your content from ranking — regardless of how good the content itself is.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What Core Web Vitals benchmarks should I aim for?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Google's current Core Web Vitals targets are: LCP (Largest Contentful Paint) at 2.5 seconds or under, INP (Interaction to Next Paint) below 200ms, and CLS (Cumulative Layout Shift) below 0.1. INP replaced FID as the responsiveness metric. These thresholds apply to real user data, not lab scores — check your Core Web Vitals report in Google Search Console for field data on actual pages.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Why are my pages not indexing?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"The most common causes are: a robots.txt block preventing Googlebot from accessing the page, a noindex tag applied accidentally, weak internal linking so Google's crawler never discovers the page, or a canonical tag pointing to a different URL. Check the Page Indexing report in Google Search Console, then use URL Inspection to see the specific reason Google hasn't indexed a given page.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Should I submit my sitemap to Google?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes. Submitting a sitemap in Google Search Console helps Google discover your pages faster, but it does not guarantee indexing. A sitemap tells Google what pages exist — Google still decides whether to index them based on quality signals, crawl budget, and accessibility. Submit your sitemap and monitor the Sitemaps report to confirm it is being processed without errors.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What should I do if I changed my URL structure?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Implement server-side 301 redirects from every old URL to its new equivalent. A 301 redirect signals to Google that the page has permanently moved, passing the majority of ranking signals to the new URL. Never delete old URLs without redirecting them — this creates 404 errors that waste crawl budget and destroy any ranking equity the old page had built.\"\n          }\n        }\n      ]\n    }\n  ]\n}\n</script> -->\n\n___________________________________________________\n\n<div class=\"service-ctm blog-ctm\">\n  <div class=\"service-ctm__body\">\n        <!--  BYLINE — add before H1, or position via CSS to suit your layout  -->\n    <p style=\"font-size: 13px; color: #888; margin: 0 0 12px; letter-spacing: 0.02em;\">\nBy <strong>Mitch Chadban</strong> — SEO &#x26; Marketing Strategist, Australia  |  Updated April 2026\n    </p>\n\n  <h1>Technical SEO Checklist (Plain English): Speed, Indexing &#x26; Site Health</h1>\n\n  <p>Technical SEO is the stuff that decides whether your site can load fast, get crawled, and actually show up in search—before your content and backlinks even get a fair shot.</p>\n\n  <p>The good news: you don’t need to be a developer to <i>manage</i> it. You just need a simple checklist, a few tools, and the confidence to spot the “this is blocking growth” problems quickly.</p>\n\n  <p>This guide gives you a practical technical SEO checklist focused on three things that move the needle in 2026:</p>\n\n  <ol>\n    <li>Speed (Core Web Vitals)</li>\n    <li>Indexing (crawl + index control)</li>\n    <li>Site health (errors, duplication, hygiene)</li>\n  </ol>\n\n  <details class=\"blog-menu\" open=\"\">\n  <summary class=\"blog-menu__header\">\n    <span class=\"blog-menu__title\">On this page</span>\n    <span aria-hidden=\"true\" class=\"blog-menu__toggle\"></span>\n  </summary>\n\n  <div class=\"blog-menu__body\">\n    <a class=\"blog-menu__item\" href=\"#triage\" onclick=\"location.hash='triage'; return false;\">The 10-minute triage: what to check first</a>\n    <a class=\"blog-menu__item\" href=\"#speed\" onclick=\"location.hash='speed'; return false;\">Part 1 — Speed checklist</a>\n    <a class=\"blog-menu__item\" href=\"#indexing\" onclick=\"location.hash='indexing'; return false;\">Part 2 — Indexing checklist</a>\n    <a class=\"blog-menu__item\" href=\"#site-health\" onclick=\"location.hash='site-health'; return false;\">Part 3 — Site health checklist</a>\n    <a class=\"blog-menu__item\" href=\"#run-this\" onclick=\"location.hash='run-this'; return false;\">I can run this for you</a>\n    <a class=\"blog-menu__item\" href=\"#founder-audit\" onclick=\"location.hash='founder-audit'; return false;\">The “founder version” audit (30 minutes)</a>\n    <a class=\"blog-menu__item\" href=\"#faq\" onclick=\"location.hash='faq'; return false;\">FAQ: Technical SEO checklist</a>\n  </div>\n</details>\n\n <h2 id=\"triage\">The 10-minute triage: what to check first</h2>\n\n  <p>If you’re time-poor, do these in order:</p>\n\n  <ol>\n    <li>Can Google access your site and key pages? (robots/noindex)</li>\n    <li>Are your important pages indexed? (Search Console)</li>\n    <li>Are your pages slow or unstable? (Core Web Vitals)</li>\n    <li>Any major site errors? (404s, redirects, canonicals, HTTPS)</li>\n  </ol>\n\n  <p>Most “SEO isn’t working” situations are one of those.</p>\n\n    <div class=\"img-full-ctm\">\n      <div class=\"img-full-ctm\">\n<img class=\"zoomable\" src=\"/images/10-minute-triage--Triage-Clipboard-Panic.jpg\" alt=\"Cursed stock photo about technical SEO triage checklist\" loading=\"lazy\" decoding=\"async\" width=\"1536\" height=\"1024\"></div></div>\n    \n    <h2 id=\"speed\">Part 1 — Speed checklist</h2>\n\n  <p>Google’s Core Web Vitals targets remain the clearest performance benchmarks:</p>\n\n  <ul>\n    <li>LCP (load): ≤ 2.5s</li>\n    <li>INP (interactivity): &#x3C; 200ms</li>\n    <li>CLS (visual stability): &#x3C; 0.1</li>\n  </ul>\n\n  <p>INP replaced FID as the responsiveness metric.</p>\n\n  <h3>Speed checklist (non-technical-friendly)</h3>\n\n  <p><strong>1) Check Core Web Vitals in Search Console</strong></p>\n  <p>This shows real user performance data.</p>\n\n  <p><strong>2) Run PageSpeed Insights on your top 5 money pages</strong></p>\n  <p>Look for LCP element issues, render-blocking scripts, heavy fonts.</p>\n\n  <p><strong>3) Fix the “big 3” causes of slow sites</strong></p>\n\n  <ul>\n    <li>Oversized images (especially hero banners)</li>\n    <li>Too many tracking scripts</li>\n    <li>Cheap hosting or overloaded servers</li>\n  </ul>\n\n  <p><strong>4) Kill layout shift (CLS)</strong></p>\n\n  <ul>\n    <li>Set image/video dimensions</li>\n    <li>Avoid injecting banners above content</li>\n    <li>Load fonts properly (or use system fonts)</li>\n  </ul>\n\n  <p><strong>5) Don’t optimize blindly</strong></p>\n  <p>Speed is page-by-page. Your pricing page matters as much as your homepage.</p>\n\n\n<h2 id=\"indexing\">Part 2 — Indexing checklist</h2>\n\n  <p>Indexing problems are usually self-inflicted:</p>\n\n  <ul>\n    <li>robots.txt blocking key areas</li>\n    <li>accidental noindex</li>\n    <li>weak internal linking</li>\n    <li>messy canonical tags</li>\n    <li>broken redirects</li>\n  </ul>\n\n  <h3>Indexing checklist</h3>\n\n  <p><strong>6) Confirm you’re not blocking Googlebot (robots.txt)</strong></p>\n\n  <p><strong>7) Use noindex correctly</strong></p>\n  <p>robots.txt is not the right way to prevent indexing.</p>\n\n  <p><strong>8) Submit a sitemap</strong></p>\n  <p>A sitemap helps discovery but is not a guarantee of indexing.</p>\n\n  <p><strong>9) Use URL Inspection in Search Console</strong></p>\n\n  <p><strong>10) Internally link important pages</strong></p>\n\n  <p><strong>11) Watch duplicate versions</strong></p>\n\n  <ul>\n    <li>/ and /index</li>\n    <li>http vs https</li>\n    <li>www vs non-www</li>\n    <li>UTM parameter versions</li>\n    <li>duplicate category/tag archives</li>\n  </ul>\n\n  <p><strong>12) Use proper 301 redirects when moving URLs</strong></p>\n\n    <div class=\"img-full-ctm\">\n      <div class=\"img-full-ctm\">\n<img class=\"zoomable\" src=\"/images/Indexing--Canonical-Doppelganger.jpg\" alt=\"Cursed stock photo about duplicate content and canonical tags\" loading=\"lazy\" decoding=\"async\" width=\"1536\" height=\"1024\"></div></div>\n    \n    <h2 id=\"site-health\">Part 3 — Site health checklist</h2>\n\n  <h3>Site health checklist</h3>\n\n  <p><strong>13) Fix 404s that get traffic or links</strong></p>\n\n  <p><strong>14) Clean up redirect chains</strong></p>\n\n  <p><strong>15) Ensure HTTPS consistency</strong></p>\n\n  <p><strong>16) Prioritise mobile usability</strong></p>\n\n  <p><strong>17) Don’t index thin/utility pages</strong></p>\n\n  <ul>\n    <li>internal search result pages</li>\n    <li>staging/dev environments</li>\n    <li>filter combinations generating thousands of URLs</li>\n  </ul>\n\n  <p><strong>18) Use structured data correctly</strong></p>\n\n    <div class=\"img-full-ctm\">\n      <div class=\"img-full-ctm\">\n<img class=\"zoomable\" src=\"/images/Speed--Oversized-Hero-Image-Weightlifting.jpg\" alt=\"Cursed stock photo about oversized images slowing websites\" loading=\"lazy\" decoding=\"async\" width=\"1536\" height=\"1024\"></div></div>\n\n<h2 id=\"run-this\">I can run this for you</h2>\n\n  <p>If you’d rather not handle this yourself, I can run this technical SEO checklist for you—identify blockers and prioritise fixes.</p>\n\n<a href=\"mailto:mitch.chadban@hotmail.com\" ><div class=\"custom-btn\"><b>Contact me</b>\n<br /></div></a> with your site URL and tell me what matters most right now: more leads, more demos, or more organic traffic.<br /><h2 id=\"founder-audit\">The “founder version” audit (30 minutes)</h2>\n\n  <ol>\n    <li>Check Page Indexing report for spikes in “Not indexed”</li>\n    <li>Check Core Web Vitals report for Poor templates</li>\n    <li>Confirm sitemap is submitted and processed</li>\n    <li>Run URL Inspection on one key underperforming page</li>\n  </ol>\n\n\n<h2 id=\"faq\">FAQ: Technical SEO checklist</h2>\n\n  <h3>What is a technical SEO checklist?</h3>\n  <p>A set of checks ensuring your site can be crawled, indexed, and served fast.</p>\n\n  <h3>What Core Web Vitals benchmarks should I aim for?</h3>\n  <p>LCP ≤ 2.5s, INP &#x3C; 200ms, CLS &#x3C; 0.1.</p>\n\n  <h3>Why are my pages not indexing?</h3>\n  <p>Common causes: robots.txt blocks, noindex tags, weak internal links, or discovery delays.</p>\n\n  <h3>Should I submit my sitemap?</h3>\n  <p>Yes. It helps discovery, though indexing is not guaranteed.</p>\n\n  <h3>What if I changed URLs?</h3>\n  <p>Use proper server-side 301 redirects based on a URL mapping.</p>\n\n\n  <h2>I can run this for you</h2>\n\n<a href=\"mailto:mitch.chadban@hotmail.com\" ><div class=\"custom-btn\"><b>Contact me</b>\n<br /></div></a> with your site URL and tell me what matters most right now: more leads, more demos, or more organic traffic.\n    \n    <div class=\"img-full-ctm\">\n      <div class=\"img-full-ctm\">\n<img class=\"zoomable\" src=\"/images/CTA--Technical-SEO-Mechanic-Workshop.jpg\" alt=\"Cursed stock photo promoting a technical SEO audit service\" loading=\"lazy\" decoding=\"async\" width=\"1536\" height=\"1024\">\n</div></div>\n\n  <div class=\"further-reading-ctm\">\n    <h4 class=\"further-reading-ctm__title\">Further Reading</h4>\n\n    <ul class=\"further-reading-ctm__list\">\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/seo-for-saas-australia-what-works-in-2026/\" >\n          SEO for SaaS in Australia: What Actually Works in 2026\n        </a>\n      </li>\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/ai-seo-vs-traditional-seo-whats-changed/\" >\n          AI SEO vs Traditional SEO: What’s Changed?\n        </a>\n      </li>\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/best-seo-and-ai-workflow-for-2026/\" >\n          Best SEO + AI Workflow for 2026\n        </a>\n      </li>\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/best-growth-marketing-channels-australia-2026/\" >\n          Best Growth Marketing Channels for 2026\n        </a>\n      </li>\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/best-ways-to-build-e-e-a-t-in-2026/\" >\n          Best Ways to Build E-E-A-T in 2026\n        </a>\n      </li>\n      <li class=\"further-reading-ctm__item\">\n        <a class=\"further-reading-ctm__link\" href=\"/from-traffic-to-demos-a-practical-funnel-for-b2b-saas/\" >\n          From Traffic to Demos: A Practical Funnel for B2B SaaS\n        </a>\n      </li>\n    </ul>\n  </div>\n\n</div></div>";
