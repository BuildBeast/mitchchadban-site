---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Creative Direction / Illustration</div>\n      <h1>The Star Hotel</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nCreative direction and illustration for a series of posters created for Newcastle’s The Star Hotel, designed to capture the venue’s lounge-like atmosphere and the eclectic, playful energy of its jazz events.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2827754451581313150780301236697/Star-2.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2827754451599759894854010788313/Star-3.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/S2827754451636653383001429891545/Star-5.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2827754451618206638927720339929/Star-4.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Z2827754451562866406706591685081/Star-1.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>The Star Hotel</strong> project centred on a poster series developed to promote jazz events at the venue. The creative approach balanced atmosphere and energy, aiming to reflect both the relaxed lounge feel of the space and the expressive, eclectic nature of the music itself.\n        </p>\n\n        <p>\nThe visual direction leaned into illustration and bold composition to create posters that felt distinct, characterful, and tied to the identity of the events rather than reading like generic venue promo material.\n        </p>\n\n        <p>\nThe result was a set of hospitality-focused promotional pieces designed to feel lively, memorable, and visually at home within Newcastle’s local music scene.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">The Star Hotel</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Creative Direction / Illustration / Poster Design</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Events</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/pinos-restaurant\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Pino’s Restaurant</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/paragon-bm\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Paragon BM</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="The Star Hotel | Mitch Chadban"
  description="Design, SEO and marketing for brands, SaaS companies and service businesses that need sharper websites, stronger content and cleaner growth systems."
  canonical="https://mitchchadban.com/the-star-hotel/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
