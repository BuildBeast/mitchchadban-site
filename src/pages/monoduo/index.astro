---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Festival Design / Campaign Assets</div>\n      <h1>MonoDuo</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nBranding elements and promotional assets created for MonoDuo Music and Arts Festival, a launch-year festival project presented by Palace and Lake Macquarie City Council.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__video portfolio-project-ctm__video--full\">\n      <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/JYZLJCbkKJw\" title=\"MonoDuo video\">\n      </iframe>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2827829649788869859988592515545/MD-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n<img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2827829649696636139620044757465/MD-3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\"></div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Z2827829649678189395546335205849/MD-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Q2827829649715082883693754309081/MD-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/B2827829649733529627767463860697/MD-6.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Q2827829649751976371841173412313/MD-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2827829649770423115914882963929/MD-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>MonoDuo Music and Arts Festival</strong> was a launch-year festival project developed with Palace and Lake Macquarie City Council. The brief involved creating core branding elements and a full range of promotional material, including posters, banners, artist tiles, and video assets.\n        </p>\n\n        <p>\nThe festival takes place in Speers Point Park on the lake, which gave the project a strong environmental and atmospheric context. The visual direction was built around the contrast between the industrial edge of techno music and the organic beauty of the surrounding landscape.\n        </p>\n\n        <p>\nThe resulting identity aimed to feel striking, contemporary, and location-aware, helping establish a memorable look and feel for the festival’s first year across both digital and physical campaign touchpoints.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">MonoDuo Music and Arts Festival</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Posters / Banners / Artist Tiles / Video Assets</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Partners</div>\n          <div class=\"portfolio-project-ctm__value\">Palace / Lake Macquarie City Council</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Speers Point Park, Lake Macquarie</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n      <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2827829649881103580357140273625/MD-15.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\"> \n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n<img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2827829649862656836283430722009/MD-14.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\"></div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/R2827829649825763348136011618777/MD-12.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://arts.lakemac.com.au\" rel=\"noopener\" target=\"_blank\">arts.lakemac.com.au</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/johnny-bird\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Johnny Bird</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/newy-fried-chicken\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Newy Fried Chicken</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="MonoDuo | Mitch Chadban"
  description="Design, SEO and marketing for brands, SaaS companies and service businesses that need sharper websites, stronger content and cleaner growth systems."
  canonical="https://mitchchadban.com/monoduo/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
