const pageContent = "<!--   SCHEMA   -->\n<!--  <script>\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Service\",\n      \"name\": \"Servicios de Diseño, Marketing y SEO\",\n      \"provider\": {\n        \"@type\": \"Person\",\n        \"name\": \"Mitch Chadban\",\n        \"url\": \"https://mitchchadban.com\"\n      },\n      \"areaServed\": {\n        \"@type\": \"Country\",\n        \"name\": \"Spain\"\n      },\n      \"hasOfferCatalog\": {\n        \"@type\": \"OfferCatalog\",\n        \"name\": \"Servicios y Paquetes\",\n        \"itemListElement\": [\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Diseño de Logotipo\",\n              \"description\": \"Diseño de logotipo profesional desde 240 € (simple) hasta 725 € (entrega profesional completa con archivos vectoriales, variaciones y reglas de uso).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Identidad de Marca\",\n              \"description\": \"Sistema de identidad de marca desde 1.100 € (mini sistema de marca) hasta 3.000 €+ (identidad completa con estrategia y despliegue).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Servicios SEO\",\n              \"description\": \"Servicios SEO desde 475 € (auditoría técnica) hasta 900 €/mes (soporte SEO mensual enfocado en métricas de negocio).\"\n            }\n          },\n          {\n            \"@type\": \"Offer\",\n            \"itemOffered\": {\n              \"@type\": \"Service\",\n              \"name\": \"Servicios de Marketing\",\n              \"description\": \"Servicios de marketing que incluyen planes de crecimiento de 90 días desde 595 €, workshops de messaging desde 895 € y soporte mensual desde 900 €/mes.\"\n            }\n          }\n        ]\n      }\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"¿Cómo sé qué servicio necesito?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Cuéntame tu objetivo — más leads, más demos, mayor consistencia de marca o mejores rankings — y tu plazo. Te recomendaré el paquete más adecuado para empezar y qué hacer a continuación.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"¿Haces presupuestos personalizados?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Sí. Todo lo que aparece como Desde depende del alcance y de cuántos activos o páginas necesites. Pide presupuesto e incluye tu briefing para recibir un precio claro.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"¿Cuál es la diferencia entre el logo de 240 € y el de 725 €?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"El logo simple de 240 € incluye un concepto y un único archivo PNG, sin sistema. El diseño de logotipo de 725 € incluye varios conceptos, revisiones, variaciones del logo y una entrega profesional con SVG y PDF.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"¿Ofreces retainers mensuales?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Sí, para diseño, marketing, SEO o una mezcla híbrida. Si necesitas producción constante, el soporte mensual suele ser la forma más rentable de trabajar juntos. Pregunta por los paquetes híbridos.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"¿Con cuánta rapidez puedes empezar?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Normalmente en una semana, según la carga de trabajo. Si tienes una fecha límite, inclúyela cuando solicites presupuesto.\"\n          }\n        }\n      ]\n    }\n  ]\n}\n</script>  -->\n\n_________________________________________________\n\n<style>\n  /* ── Service block layout ────────────────────────────────── */\n  .mc-pricing {\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .mc-pricing h1 {\n    margin-bottom: 0.5rem;\n  }\n\n  .mc-pricing .mc-intro {\n    margin-bottom: 2rem;\n    line-height: 1.6;\n  }\n\n  /* ── Accordion ───────────────────────────────────────────── */\n  .pricing-acc {\n    border-top: 1px solid #e2e2e2;\n    margin: 2rem 0;\n  }\n\n  .pricing-acc__item {\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .pricing-acc__sum {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 1.25rem 0;\n    font-size: 1.1rem;\n    font-weight: 700;\n    cursor: pointer;\n    list-style: none;\n    user-select: none;\n  }\n\n  .pricing-acc__sum::-webkit-details-marker { display: none; }\n\n  .pricing-acc__sum::after {\n    content: &#x27;+&#x27;;\n    font-size: 1.4rem;\n    font-weight: 300;\n    line-height: 1;\n  }\n\n  .pricing-acc__item[open] &#x3E; .pricing-acc__sum::after {\n    content: &#x27;−&#x27;;\n  }\n\n  .pricing-acc__body {\n    padding: 0.5rem 0 2rem;\n  }\n\n  /* ── Service blocks ──────────────────────────────────────── */\n  .mc-service {\n    margin-bottom: 2.5rem;\n    padding-bottom: 2.5rem;\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .mc-service:last-child {\n    margin-bottom: 0;\n    padding-bottom: 0;\n    border-bottom: none;\n  }\n\n  .mc-service h3 {\n    margin: 0 0 0.25rem;\n  }\n\n  .mc-service__price {\n    font-weight: 600;\n    margin: 0 0 0.5rem;\n  }\n\n  .mc-service__desc {\n    margin: 0 0 1rem;\n    line-height: 1.6;\n  }\n\n  .mc-service__label {\n    font-weight: 700;\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin: 1rem 0 0.4rem;\n  }\n\n  .mc-service ul {\n    margin: 0 0 0.75rem;\n    padding-left: 1.25rem;\n  }\n\n  .mc-service ul li {\n    margin-bottom: 0.3rem;\n    line-height: 1.5;\n  }\n\n  .mc-service__bestfor {\n    font-size: 0.9rem;\n    margin: 0.75rem 0 0;\n  }\n\n  /* ── Shortcut section ────────────────────────────────────── */\n  .mc-shortcut {\n    background: #f7f7f7;\n    border-radius: 6px;\n    padding: 2rem;\n    margin: 2rem 0;\n  }\n\n  .mc-shortcut h2 {\n    margin: 0 0 1rem;\n  }\n\n  .mc-shortcut ul {\n    margin: 0 0 1.5rem;\n    padding-left: 1.25rem;\n  }\n\n  .mc-shortcut ul li {\n    margin-bottom: 0.5rem;\n    line-height: 1.5;\n  }\n\n  /* ── FAQ ─────────────────────────────────────────────────── */\n  .mc-faq {\n    margin: 2.5rem 0;\n  }\n\n  .mc-faq h2 {\n    margin-bottom: 1.5rem;\n  }\n\n  .mc-faq__item {\n    margin-bottom: 1.5rem;\n    padding-bottom: 1.5rem;\n    border-bottom: 1px solid #e2e2e2;\n  }\n\n  .mc-faq__item:last-child {\n    border-bottom: none;\n  }\n\n  .mc-faq__item h3 {\n    margin: 0 0 0.5rem;\n  }\n\n  .mc-faq__item p {\n    margin: 0;\n    line-height: 1.6;\n  }\n\n  /* ── CTA button spacing ──────────────────────────────────── */\n  .mc-pricing .custom-btn {\n    margin-top: 0.5rem;\n  }\n</style>\n\n<div class=\"mc-pricing\">\n\n  <h1>Precios y Paquetes</h1>\n\n  <p class=\"mc-intro\">\nElige el servicio que necesitas. Obtén entregables claros. Avanza rápido.<br />\n¿No sabes cuál elegir? Solicita un presupuesto y te recomendaré el paquete que mejor encaje según tu objetivo, tu plazo y el punto en el que estás.\n  </p>\n\n  <a href=\"/contact-form/\" >\n    <div class=\"custom-btn\"><b>Solicitar presupuesto</b></div>\n  </a>\n\n  <div class=\"pricing-acc\">\n\n    <details class=\"pricing-acc__item\" open=\"\">\n      <summary class=\"pricing-acc__sum\">Ilustración</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Ilustración Personalizada (Pieza Única)</h3>\n          <p class=\"mc-service__price\">Desde 275 €</p>\n          <p class=\"mc-service__desc\">Una ilustración personalizada para web, redes, impresión o producto.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>1 dirección conceptual</li>\n            <li>1 ronda de revisión</li>\n            <li>Archivos finales (PNG + SVG/PDF según el estilo)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> gráficos hero, cabeceras de blog, visuales de campaña</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Pack de Ilustración (3–5 Piezas)</h3>\n          <p class=\"mc-service__price\">Desde 725 €</p>\n          <p class=\"mc-service__desc\">Un conjunto de ilustraciones diseñado para funcionar como un sistema coherente.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Alineación de estilo para que todo encaje</li>\n            <li>3–5 ilustraciones</li>\n            <li>2 rondas de revisión</li>\n            <li>Pack de exportación para web/redes</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> landing pages, series de contenido, visuales de marca</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Soporte Mensual de Ilustración</h3>\n          <p class=\"mc-service__price\">Desde 550 € / mes</p>\n          <p class=\"mc-service__desc\">Producción continua de ilustración con una cola mensual simple de prioridades.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Planificación mensual</li>\n            <li>Cola prioritaria</li>\n            <li>2–6 ilustraciones al mes según complejidad</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <details class=\"pricing-acc__item\" open=\"\">\n      <summary class=\"pricing-acc__sum\">Diseño</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Pack de Plantillas Sociales (Core 5)</h3>\n          <p class=\"mc-service__price\">595 €</p>\n          <p class=\"mc-service__desc\">Un sistema de plantillas que parece tu marca, no un pack genérico de Canva.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>5 plantillas: valor, carrusel, prueba, comparación y oferta</li>\n            <li>Tipografía y reglas de espaciado integradas</li>\n            <li>Entregado en Canva (o en Figma bajo petición)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> publicar con consistencia sin reinventar el diseño cada semana</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Pack de Material Comercial</h3>\n          <p class=\"mc-service__price\">Desde 900 €</p>\n          <p class=\"mc-service__desc\">Tus activos clave de ventas y marketing diseñados para convertir.</p>\n          <p class=\"mc-service__label\">Incluye habitualmente</p>\n          <ul>\n            <li>One-pager / dossier de capacidades</li>\n            <li>Plantilla de presentación</li>\n            <li>Plantilla de caso de estudio</li>\n            <li>Plantilla de propuesta</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> negocios de servicios y equipos B2B con ofertas de ticket alto</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Diseño de Landing Page (Enfocado en Conversión)</h3>\n          <p class=\"mc-service__price\">Desde 1.100 €</p>\n          <p class=\"mc-service__desc\">Una landing page diseñada para claridad, prueba y conversión.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Wireframe + diseño final</li>\n            <li>Versión móvil</li>\n            <li>Notas para handoff a desarrollo (o opción de build)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> anuncios, lead magnets, ofertas de servicios y lanzamientos</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Soporte Mensual de Diseño</h3>\n          <p class=\"mc-service__price\">Desde 725 € / mes</p>\n          <p class=\"mc-service__desc\">Producción de diseño constante sin necesidad de contratar in-house.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Prioridades mensuales + cadencia de entrega</li>\n            <li>Piezas para redes y anuncios</li>\n            <li>Actualización de materiales</li>\n            <li>Revisión de consistencia de marca</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <details class=\"pricing-acc__item\" open=\"\">\n      <summary class=\"pricing-acc__sum\">Branding</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Logo Simple (Sin Activos)</h3>\n          <p class=\"mc-service__price\">240 €</p>\n          <p class=\"mc-service__desc\">Un concepto de logo básico para uso rápido, sin sistema de marca ni suite de archivos.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>1 concepto</li>\n            <li>1 ronda de revisión</li>\n            <li>1 archivo final del logo (PNG)</li>\n          </ul>\n          <p class=\"mc-service__label\">No incluye</p>\n          <ul>\n            <li>Variaciones del logo (apilado/icono)</li>\n            <li>Archivos vectoriales (SVG/AI/EPS)</li>\n            <li>Versiones de color</li>\n            <li>Guías ni plantillas</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> proyectos en fase inicial que solo necesitan algo simple</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Diseño de Logotipo (Entrega Profesional)</h3>\n          <p class=\"mc-service__price\">725 €</p>\n          <p class=\"mc-service__desc\">Un sistema de logo limpio que funciona en web, redes e impresión.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>2–3 conceptos</li>\n            <li>2 rondas de revisión</li>\n            <li>Logo principal + apilado + icono</li>\n            <li>Versiones de color (completo/negro/blanco)</li>\n            <li>Archivos: SVG, PNG, PDF (AI/EPS bajo petición)</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> negocios que quieren credibilidad y los archivos correctos</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Mini Sistema de Marca (Mejora Rápida de Consistencia)</h3>\n          <p class=\"mc-service__price\">1.100 €</p>\n          <p class=\"mc-service__desc\">Deja de parecer aleatorio entre redes, web y documentos.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Sistema de color + tipografía</li>\n            <li>Reglas de espaciado y layout</li>\n            <li>Dirección de foto/estilo</li>\n            <li>Mini guía de marca (PDF)</li>\n            <li>Plantillas iniciales (social o docs)</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Refresh de Marca (Marca Existente, Mejorada)</h3>\n          <p class=\"mc-service__price\">Desde 1.500 €</p>\n          <p class=\"mc-service__desc\">Mantén tu marca reconocible, pero hazla más premium y consistente.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Paleta y tipografía refinadas</li>\n            <li>Uso actualizado del logo si hace falta</li>\n            <li>Plantillas renovadas</li>\n            <li>Guías actualizadas</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Identidad de Marca Completa (Estrategia + Sistema)</h3>\n          <p class=\"mc-service__price\">Desde 3.000 €</p>\n          <p class=\"mc-service__desc\">Para rebrands o marcas que escalan a mercados más grandes.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Discovery + dirección creativa</li>\n            <li>Sistema de identidad (logo, color, tipografía, visuales)</li>\n            <li>Guías</li>\n            <li>Plantillas de despliegue (redes + deck + docs)</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">Marketing</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Plan de Crecimiento (90 días)</h3>\n          <p class=\"mc-service__price\">595 €</p>\n          <p class=\"mc-service__desc\">Un plan enfocado: qué hacer ahora y qué ignorar.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Sesión de trabajo de 60–90 min</li>\n            <li>Revisión de canales + funnel</li>\n            <li>Hoja de ruta de 90 días (acciones semanales)</li>\n            <li>Cuadro de KPIs</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Workshop de Messaging (Posicionamiento → Anuncios que Convierten)</h3>\n          <p class=\"mc-service__price\">895 €</p>\n          <p class=\"mc-service__desc\">Resuelve el problema de “la segmentación está bien pero los anuncios no convierten”.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Claridad sobre ICP + categoría</li>\n            <li>Diferenciadores + pruebas</li>\n            <li>Framework de mensajes (hooks, ángulos, propuestas de valor)</li>\n            <li>Pack de ángulos para anuncios (10–15)</li>\n            <li>Esquema de copy hero para landing page</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Mapeo de Funnel (Tráfico → Leads → Demos)</h3>\n          <p class=\"mc-service__price\">475 €</p>\n          <p class=\"mc-service__desc\">Encuentra el cuello de botella que te está costando leads y reuniones agendadas.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Revisión del funnel + análisis de fugas</li>\n            <li>Comparación con benchmarks</li>\n            <li>Lista de prioridades</li>\n            <li>Quick wins de conversión</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Soporte Mensual de Marketing</h3>\n          <p class=\"mc-service__price\">Desde 900 € / mes</p>\n          <p class=\"mc-service__desc\">Soporte de ejecución ligado a resultados de negocio.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Planificación mensual</li>\n            <li>Construcción de campañas</li>\n            <li>Reporting enfocado en leads + conversión</li>\n            <li>Coordinación de creatividad/copy cuando haga falta</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n    <details class=\"pricing-acc__item\">\n      <summary class=\"pricing-acc__sum\">,SEO</summary>\n      <div class=\"pricing-acc__body\">\n\n        <div class=\"mc-service\">\n          <h3>Auditoría Técnica SEO (En Lenguaje Claro)</h3>\n          <p class=\"mc-service__price\">475 €</p>\n          <p class=\"mc-service__desc\">Velocidad, indexación, duplicación, salud del sitio: lo que bloquea tus rankings.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Revisión de Search Console + crawl</li>\n            <li>Prioridades de Core Web Vitals</li>\n            <li>Comprobación de indexación + canonicals</li>\n            <li>Plan de acción listo para desarrollo</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Auditoría SEO + AEO (Búsqueda + Respuestas de IA)</h3>\n          <p class=\"mc-service__price\">780 €</p>\n          <p class=\"mc-service__desc\">Haz que tu sitio sea más fácil de posicionar y también más fácil de citar en respuestas de IA.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Revisión técnica + estructural</li>\n            <li>Mejoras de contenido extraíble (resúmenes/FAQs/tablas)</li>\n            <li>Huecos de E-E-A-T/pruebas</li>\n            <li>Plan de despliegue 30/60/90</li>\n          </ul>\n          <p class=\"mc-service__label\">No incluye</p>\n          <ul>\n            <li>Redacción de contenido ni creación de páginas</li>\n            <li>Monitorización continua ni implementación</li>\n          </ul>\n          <p class=\"mc-service__bestfor\"><strong>Ideal para:</strong> sitios que ya reciben tráfico y quieren aparecer en motores de respuesta con IA</p>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>SEO de Intención de Compra (Money Pages)</h3>\n          <p class=\"mc-service__price\">Desde 1.500 €</p>\n          <p class=\"mc-service__desc\">Construye las páginas que generan consultas: comparativas, alternativas, servicios e integraciones.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Mapa de keywords con intención de compra</li>\n            <li>Briefs de página + plan de enlazado interno</li>\n            <li>SEO on-page</li>\n            <li>Soporte de publicación (opcional)</li>\n          </ul>\n        </div>\n\n        <div class=\"mc-service\">\n          <h3>Soporte SEO Mensual</h3>\n          <p class=\"mc-service__price\">Desde 900 € / mes</p>\n          <p class=\"mc-service__desc\">Crecimiento acumulativo desde búsqueda, ligado a leads y no a tráfico vanity.</p>\n          <p class=\"mc-service__label\">Incluye</p>\n          <ul>\n            <li>Roadmap de contenido + briefs</li>\n            <li>Mejoras on-page</li>\n            <li>Enlazado interno</li>\n            <li>Revisiones técnicas de higiene</li>\n            <li>Reporting orientado a conversión</li>\n          </ul>\n        </div>\n\n      </div>\n    </details>\n\n  </div>\n\n  <div class=\"mc-shortcut\">\n    <h2>¿No sabes qué elegir?</h2>\n    <ul>\n      <li>¿Quieres verte consistente rápido? → <strong>Mini Sistema de Marca</strong></li>\n      <li>¿Necesitas contenido social que se vea premium? → <strong>Pack de Plantillas Sociales</strong></li>\n      <li>¿Tus anuncios reciben clics pero no leads? → <strong>Workshop de Messaging</strong></li>\n      <li>¿Tienes tráfico pero no demos? → <strong>Mapeo de Funnel</strong></li>\n      <li>¿Tu sitio no posiciona? → <strong>Auditoría Técnica SEO</strong></li>\n      <li>¿Quieres visibilidad en búsqueda + respuestas de IA? → <strong>Auditoría SEO + AEO</strong></li>\n      <li>¿Necesitas producción continua en diseño, marketing o SEO? → <strong>Retainer mensual — pregúntame por un paquete híbrido</strong></li>\n    </ul>\n    <a href=\"/contact-form/\" >\n      <div class=\"custom-btn\"><b>Solicitar presupuesto</b></div>\n    </a>\n  </div>\n\n  <div class=\"mc-faq\">\n    <h2>FAQ: Precios y Paquetes</h2>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Cómo sé qué servicio necesito?</h3>\n      <p>Cuéntame tu objetivo (más leads, más demos, mayor consistencia de marca o mejores rankings) y tu plazo. Te recomendaré el mejor paquete para empezar y qué hacer a continuación.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Haces presupuestos personalizados?</h3>\n      <p>Sí. Todo lo marcado como “Desde” depende del alcance y de cuántos activos o páginas necesites.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Cuál es la diferencia entre el logo de 240 € y el de 725 €?</h3>\n      <p>El Logo Simple de 240 € incluye un concepto, un único PNG y ningún sistema. El Diseño de Logotipo de 725 € incluye varios conceptos, revisiones, variaciones del logo y una entrega profesional con SVG y PDF.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Puedo seguir usando Canva después de que me prepares las plantillas?</h3>\n      <p>Sí, esa es la idea. Las plantillas y las reglas te dan velocidad sin que tu marca pierda consistencia.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Ofreces retainers mensuales?</h3>\n      <p>Sí: para diseño, marketing, SEO o una mezcla híbrida. Si necesitas producción constante, el soporte mensual suele ser la forma más rentable de trabajar juntos.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Con cuánta rapidez puedes empezar?</h3>\n      <p>Normalmente en una semana, según la carga de trabajo. Si tienes una fecha límite, inclúyela cuando solicites presupuesto.</p>\n    </div>\n\n    <div class=\"mc-faq__item\">\n      <h3>¿Qué necesitas de mí para empezar?</h3>\n      <p>Un enlace a tu web, tus redes si son relevantes, ejemplos que te gusten y una nota breve sobre tu cliente ideal y cómo sería el éxito para este proyecto.</p>\n    </div>\n\n  </div>\n\n  <a href=\"/contact-form/\" >\n    <div class=\"custom-btn\"><b>Solicitar presupuesto</b></div>\n  </a>\n<br />\n<br />\n</div>";
