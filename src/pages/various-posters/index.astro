---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Posters / Event Design / Ongoing Work</div>\n      <h1>Various Posters</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nA growing collection of recent poster designs created for parties, events, and live experiences, with all art direction and design handled by me.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/p-3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Various Posters</strong> is an ongoing collection of recent poster work developed for parties, events, and promotional campaigns. The pieces range across different briefs and atmospheres, but all sit within a broader approach that values strong composition, visual character, and clarity in communication.\n        </p>\n\n        <p>\nEach poster combines art direction and design with the goal of creating event visuals that feel memorable, distinctive, and tailored to the energy of the occasion rather than relying on generic promotional tropes.\n        </p>\n\n        <p>\nThis section will continue to grow over time as new poster work is added.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Various Posters</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Art Direction / Poster Design / Event Promotion</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Format</div>\n          <div class=\"portfolio-project-ctm__value\">Posters / Events / Parties</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Status</div>\n          <div class=\"portfolio-project-ctm__value\">Ongoing / Updated Regularly</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/P-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/biggs/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Biggs Coffee</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/archive/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Archive</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Various Posters | Mitch Chadban"
  description="A growing collection of poster designs for parties, events and live experiences, with art direction and design built around bold composition and visual character."
  canonical="https://mitchchadban.com/various-posters/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
