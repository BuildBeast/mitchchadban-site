---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm portfolio-project-ctm--biggs\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Hospitality / Identity Design</div>\n      <h1>Biggs Coffee</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nBranding developed for the launch of Biggs Coffee, a Hamilton café positioned near the train station with an identity inspired by the infamous UK train robber Ronald Biggs.\n      </p>\n    </div>\n\n    <hr />\n\n    <!--  HERO  -->\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/Biggs7.jpg\" alt=\"Bigg logo on the biggs app\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <!--  SUPPORTING 2-UP  -->\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-17.jpg\" alt=\"Biggs logo on white background\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-12.jpg\" alt=\"Biggs menu pamphlet design\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Biggs Coffee</strong> was a branding project developed for the launch of a new café in Hamilton. The venue’s location near a train station heavily influenced the creative concept behind the identity.\n        </p>\n\n        <p>\nThe owners led the art direction for the project and positioned the café around Ronald Biggs, the infamous UK train robber. The brief focused on building a series of scalable branding elements that could be applied consistently across the venue and its marketing materials.\n        </p>\n\n        <p>\nThe central logo concept references the hand gesture Biggs was known for, creating a distinctive and memorable symbol that ties the café’s identity back to the train-inspired theme while remaining playful, recognisable, and easy to deploy across signage, menus, apparel, and branded touchpoints.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Biggs Coffee</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Identity Design / Visual System</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Café</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Hamilton, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <!--  DETAIL ROW  -->\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-3.jpg\" alt=\"Biggs store front image 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-14.jpg\" alt=\"Biggs logo on a blurry background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-4.jpg\" alt=\"Biggs menu board\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <!--  FINAL 2-UP  -->\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-13.jpg\" alt=\"Biggs logo on a blurry background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-2.jpg\" alt=\"Biggs store front image 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/empowered-community-services/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Empowered Community Services</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/archive/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Archive</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Biggs | Mitch Chadban"
  description="See the Biggs Coffee branding project — a Hamilton NSW cafe identity inspired by UK train robber Ronald Biggs, with a scalable logo and visual system across signage."
  canonical="https://mitchchadban.com/biggs/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
