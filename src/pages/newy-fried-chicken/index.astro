---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Art Direction / Illustration</div>\n      <h1>Newy Fried Chicken</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nArt direction, illustration, and layout work created for Newcastle’s favourite fried chicken joint, developing playful brand assets, posters, and merchandise with a modern retro character style.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2828867157449845368005080504793/NFC-10.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/J2828867157431398623931370953177/NFC-9.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/O2828867157468292112078790056409/NFC-11.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/E2828867157523632344299918711257/NFC-14.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/A2828867157542079088373628262873/NFC-15.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2828867157505185600226209159641/NFC-13.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2828867157486738856152499608025/NFC-12.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Newy Fried Chicken</strong> is a Newcastle staple known for its bold personality and loyal following. The project involved developing a range of visual assets including illustration, layout design, posters, and merchandise.\n        </p>\n\n        <p>\nThe creative direction leaned heavily into playful character design inspired by classic anthropomorphic retro mascots, updated with a modern graphic style that felt energetic and welcoming.\n        </p>\n\n        <p>\nAcross the various projects, the goal was to create work that felt fun, distinctive, and instantly recognisable while still remaining flexible enough to be applied across posters, merchandise, and brand-related touchpoints.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Newy Fried Chicken</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Art Direction / Illustration / Posters / Merchandise</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Fast Food</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/M2828867157412951879857661401561/NFC-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/F2828867157394505135783951849945/NFC-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/K2828867157376058391710242298329/NFC-6.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2828867157283824671341694540249/NFC-1.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/R2828867157302271415415404091865/NFC-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2828867157320718159489113643481/NFC-3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2828867157339164903562823195097/NFC-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2828867157357611647636532746713/NFC-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/V2828867157560525832447337814489/NFC-g.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/H2828867157578972576521047366105/NFC-gg.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://newyfriedchicken.com\" rel=\"noopener\" target=\"_blank\">newyfriedchicken.com</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/monoduo\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">MonoDuo</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/empowered-community-services\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Empowered Community Services</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Newy Fried Chicken | Mitch Chadban"
  description="Design, SEO and marketing for brands, SaaS companies and service businesses that need sharper websites, stronger content and cleaner growth systems."
  canonical="https://mitchchadban.com/newy-fried-chicken/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
