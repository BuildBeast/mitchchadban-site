---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"mc-about\">\n\n  <h1>Terms of Service (Services)</h1>\n  <p><b>Last updated:</b> 22 February 2026</p>\n\n  <p>\nThese Terms apply to services provided via mitchchadban.com (“we”, “us”, “our”) to you (“you”, “client”).\n    By engaging us for services, you agree to these Terms.\n  </p>\n\n  <h2>1) Scope of work</h2>\n  <p>\nThe scope, deliverables, timeline, and price will be defined in writing (quote, proposal, or written confirmation) before work begins.\n  </p>\n  <p>\nWork outside the agreed scope (new pages, new formats, new directions, additional deliverables) may require a revised quote and timeline.\n  </p>\n\n  <h2>2) Quotes and approvals</h2>\n  <ul>\n    <li>Quotes are valid for 14 days unless stated otherwise.</li>\n    <li>Work starts once you approve the scope and any required deposit is paid (if applicable).</li>\n  </ul>\n\n  <h2>3) Payment</h2>\n  <ul>\n    <li>Unless otherwise agreed, invoices are due within 7 days.</li>\n    <li>For larger projects, we may require a deposit and/or milestone payments.</li>\n    <li>Late payment may pause work and delay timelines.</li>\n  </ul>\n\n  <h2>4) Revisions</h2>\n  <ul>\n    <li>Revision rounds included are defined in your package/scope.</li>\n    <li>A “revision round” means a set of changes provided in one consolidated response.</li>\n    <li>Additional rounds, new directions, or changes beyond scope may be billed or quoted separately.</li>\n  </ul>\n\n  <h2>5) Timelines and client responsibilities</h2>\n  <ul>\n    <li>Timelines depend on timely feedback and provision of required materials (brand assets, content, access, etc.).</li>\n    <li>Delays in feedback may push delivery dates.</li>\n  </ul>\n\n  <h2>6) Deliverables and handover</h2>\n  <p>\nFinal deliverables will be provided in the formats listed in your scope (e.g., PNG, PDF, SVG, editable files where included).\n  </p>\n  <p>\nSource/editable files are only included if specified in the package/scope.\n  </p>\n\n  <h2>7) Intellectual property (IP) and usage</h2>\n\n  <h3>a) Ownership</h3>\n  <p>\nOnce full payment is received, you own the final approved deliverables, unless otherwise stated in writing.\n   Working files, drafts, and unused concepts remain our property unless explicitly transferred.\n  </p>\n\n  <h3>b) Portfolio use</h3>\n  <p>\nWe may display the work in our portfolio/socials unless you request confidentiality in writing before the project starts.\n  </p>\n\n  <h3>c) Third-party assets</h3>\n  <p>\nIf the project uses third-party assets (fonts, stock imagery, plugins), you may need to purchase appropriate licenses.\n Where required, this will be communicated.\n  </p>\n\n  <h2>8) Cancellations and pauses</h2>\n  <ul>\n    <li>You may cancel by written notice. Work completed up to the cancellation date will be invoiced and payable.</li>\n    <li>Deposits are generally non-refundable once work has commenced (unless required by law).</li>\n    <li>If a project is paused for 30 days due to client inactivity, we may close the project. Resuming may require a restart fee and revised timeline.</li>\n  </ul>\n\n  <h2>9) Results and performance (marketing/SEO)</h2>\n  <p>\nFor marketing, SEO, and related services, outcomes can be influenced by factors outside our control (platform changes, competition, site constraints, budgets).\n  </p>\n  <p>\nWe do not guarantee specific rankings, traffic, or revenue results unless explicitly agreed in writing.\n  </p>\n\n  <h2>10) Liability</h2>\n  <p>\nTo the maximum extent permitted by law, we are not liable for indirect or consequential losses (including lost profits or opportunities).\n  </p>\n  <p>\nOur total liability for any claim is limited to the fees paid for the services giving rise to the claim.\n  </p>\n\n  <h2>11) Confidentiality</h2>\n  <p>\nBoth parties agree to keep confidential information private, except where disclosure is required by law or necessary to deliver services\n (e.g., subcontractors bound by confidentiality).\n  </p>\n\n  <h2>12) Governing law</h2>\n  <p>\nThese Terms are governed by the laws of New South Wales, Australia, and you submit to the jurisdiction of its courts.\n  </p>\n\n  <h2>13) Contact</h2>\n  <p>\nQuestions about these Terms can be submitted via the Site contact form: <a href=\"/contact-form/\" >https://mitchchadban.com/contact</a>\n \n  </p>\n<br />\n  <br />\n</div>";
---

<BaseLayout
  title="Terms of Service | Mitch Chadban"
  description="Terms of Service for mitchchadban.com design, SEO and marketing work: scope, quotes, payment, revisions, IP ownership, cancellations and governing law."
  canonical="https://mitchchadban.com/terms-of-service/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
