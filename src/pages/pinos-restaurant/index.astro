---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Illustration / Design</div>\n      <h1>Pino’s Restaurant</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nVarious illustrations and design work created for Pino’s — a long-standing (Now Closed) Novocastrian vegetarian staple in Newcastle, NSW.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Pino-s1.jpg\" alt=\"Shirt design for Pinos restaurant\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Pinos-4.jpg\" alt=\"Pasta Illustration design for Pinos restaurant\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pino2.jpg\" alt=\"Menu design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pinos-3.jpg\" alt=\"Pattern design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pinos5.jpg\" alt=\"Menu design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Pino’s Restaurant</strong> involved a range of illustration and design work developed to support the venue’s visual presence. The project sat within a hospitality context, balancing character, warmth, and recognisable visual styling across different pieces of creative.\n        </p>\n\n        <p>\nThe work focused on building assets that felt playful, memorable, and aligned with the personality of the restaurant, while still being practical for real-world use across promotional and brand-adjacent applications.\n        </p>\n\n        <p>\nIf you’re in Newcastle, NSW, this place is absolutely worth a visit.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Pino’s Restaurant</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Illustration / Design / Hospitality Assets</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/kryoz/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Kryoz Gardening</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/the-star-hotel/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">The Star Hotel</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Pinos Restaurant | Mitch Chadban"
  description="Illustration and design work for Pino's in Newcastle, NSW: playful menus, patterns and brand assets full of personality."
  canonical="https://mitchchadban.com/pinos-restaurant/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/pinos-restaurant/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/pinos-restaurant/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/pinos-restaurant/' }
  ]}
>
  <Fragment set:html={pageContent} />
