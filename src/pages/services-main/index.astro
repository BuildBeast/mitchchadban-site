---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"c2-hero\" id=\"c2Hero\">\n  <canvas aria-hidden=\"true\" height=\"1364\" id=\"mcLava\" style=\"width: 1339px; height: 682px;\" width=\"2678\"></canvas>\n  <div aria-hidden=\"true\" class=\"lava-follow\" style=\"--mx: 635.9687500000003px; --my: 3.7265625000000013px;\"></div>\n\n  <div class=\"c2-hero__inner\">\n    <div class=\"c2-hero__top\">\n      <h1 class=\"c2-hero__pill\">Services</h1>\n      <div class=\"c2-hero__who\">What I do</div>\n    </div>\n\n    <nav aria-label=\"Services\" class=\"c2-hero__nav\">\n      <a class=\"c2-hero__item\" href=\"/commercial-illustration-(digital-+-print)/\" >\n        <span class=\"c2-hero__num\">01</span>\n        <span class=\"c2-hero__title\">Illustration</span>\n        <span class=\"c2-hero__desc\">Digital + print</span>\n      </a>\n\n      <a class=\"c2-hero__item\" href=\"/graphic-designer-for-modern-brands/\" >\n        <span class=\"c2-hero__num\">02</span>\n        <span class=\"c2-hero__title\">Design</span>\n        <span class=\"c2-hero__desc\">Web + assets</span>\n      </a>\n\n      <a class=\"c2-hero__item\" href=\"/branding-designer-(logos-+-visual-identity)/\" >\n        <span class=\"c2-hero__num\">03</span>\n        <span class=\"c2-hero__title\">Branding</span>\n        <span class=\"c2-hero__desc\">Identity systems</span>\n      </a>\n\n      <a class=\"c2-hero__item\" href=\"/growth-marketing-consultant-for-saas-startups/\" >\n        <span class=\"c2-hero__num\">04</span>\n        <span class=\"c2-hero__title\">Marketing</span>\n        <span class=\"c2-hero__desc\">Growth strategy</span>\n      </a>\n\n      <a class=\"c2-hero__item\" href=\"/seo-for-saas-startups/\" >\n        <span class=\"c2-hero__num\">05</span>\n        <span class=\"c2-hero__title\">SEO</span>\n        <span class=\"c2-hero__desc\">Search + content</span>\n      </a>\n    </nav>\n\n    <div class=\"c2-hero__bottom\">\n      <a class=\"c2-hero__cta\" href=\"mailto:mitch.chadban@hotmail.com\" >Get a quote</a>\n    </div>\n  </div>\n\n  <script>\n    (() => {\n      const oldBg = document.getElementById(\"mc-bg\");\n      if (oldBg) oldBg.remove();\n\n      const hero = document.getElementById(\"c2Hero\");\n      const c = document.getElementById(\"mcLava\");\n      if (!hero || !c) return;\n\n      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;\n\n      const ctx = c.getContext(\"2d\", { alpha: true });\n      let w = 0, h = 0, dpr = 1;\n\n      function resize(){\n        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));\n        w = hero.clientWidth;\n        h = hero.clientHeight;\n\n        c.width = Math.floor(w * dpr);\n        c.height = Math.floor(h * dpr);\n        c.style.width = w + \"px\";\n        c.style.height = h + \"px\";\n\n        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n      }\n\n      const ro = new ResizeObserver(resize);\n      ro.observe(hero);\n      window.addEventListener(\"resize\", resize, { passive:true });\n      resize();\n\n      const mouse = { x: w*0.5, y: h*0.5, tx: w*0.5, ty: h*0.5, active:false };\n\n      function setMouse(e){\n        const r = hero.getBoundingClientRect();\n        mouse.tx = e.clientX - r.left;\n        mouse.ty = e.clientY - r.top;\n        mouse.active = true;\n      }\n\n      hero.addEventListener(\"pointermove\", setMouse, { passive:true });\n      hero.addEventListener(\"pointerenter\", setMouse, { passive:true });\n      hero.addEventListener(\"pointerleave\", () => { mouse.active = false; }, { passive:true });\n\n      const GREEN = \"rgba(0,200,83,\";\n      const blobCount = 10;\n\n      function rand(min,max){ return min + Math.random()*(max-min); }\n\n      const blobs = Array.from({length: blobCount}, () => {\n        const r = rand(Math.min(w,h)*0.10, Math.min(w,h)*0.20);\n        return {\n          x: rand(0,w), y: rand(0,h),\n          vx: rand(-0.35,0.35), vy: rand(-0.35,0.35),\n          r,\n          seed: Math.random()*1000\n        };\n      });\n\n      function drawBlob(x,y,r,alpha){\n        const g = ctx.createRadialGradient(x,y, r*0.10, x,y, r);\n        g.addColorStop(0, `${GREEN}${alpha})`);\n        g.addColorStop(1, `${GREEN}0)`);\n        ctx.fillStyle = g;\n        ctx.beginPath();\n        ctx.arc(x,y,r,0,Math.PI*2);\n        ctx.fill();\n      }\n\n      let t = 0;\n\n      function tick(){\n        t += 0.008;\n\n        mouse.x += (mouse.tx - mouse.x) * 0.08;\n        mouse.y += (mouse.ty - mouse.y) * 0.08;\n\n        ctx.clearRect(0,0,w,h);\n\n        ctx.globalCompositeOperation = \"source-over\";\n        drawBlob(w*0.35, h*0.55, Math.min(w,h)*0.42, 0.10);\n        drawBlob(w*0.72, h*0.45, Math.min(w,h)*0.38, 0.08);\n\n        ctx.globalCompositeOperation = \"screen\";\n        ctx.filter = \"blur(18px)\";\n\n        for (const b of blobs){\n          b.x += b.vx + Math.sin(t + b.seed) * 0.12;\n          b.y += b.vy + Math.cos(t + b.seed) * 0.12;\n\n          if (b.x < -b.r) b.x = w + b.r;\n          if (b.x > w + b.r) b.x = -b.r;\n          if (b.y < -b.r) b.y = h + b.r;\n          if (b.y > h + b.r) b.y = -b.r;\n\n          if (mouse.active){\n            const dx = mouse.x - b.x;\n            const dy = mouse.y - b.y;\n            const dist = Math.hypot(dx,dy) || 1;\n\n            const pullRadius = 520;\n            if (dist < pullRadius){\n              const pull = (1 - dist/pullRadius) * 0.22;\n              b.vx += (dx / dist) * pull * 0.02;\n              b.vy += (dy / dist) * pull * 0.02;\n            }\n          }\n\n          b.vx *= 0.985;\n          b.vy *= 0.985;\n\n          const pulse = 1 + Math.sin(t*1.8 + b.seed) * 0.05;\n          drawBlob(b.x, b.y, b.r * pulse, 0.22);\n        }\n\n        ctx.filter = \"none\";\n        ctx.globalCompositeOperation = \"source-over\";\n\n        requestAnimationFrame(tick);\n      }\n\n      requestAnimationFrame(tick);\n    })();\n\n    (() => {\n      const el = document.querySelector('#c2Hero .lava-follow');\n      if (!el) return;\n\n      let targetX = window.innerWidth * 0.5;\n      let targetY = window.innerHeight * 0.5;\n      let currentX = targetX;\n      let currentY = targetY;\n\n      const ease = 0.14;\n\n      function animate(){\n        currentX += (targetX - currentX) * ease;\n        currentY += (targetY - currentY) * ease;\n\n        el.style.setProperty('--mx', currentX + 'px');\n        el.style.setProperty('--my', currentY + 'px');\n\n        requestAnimationFrame(animate);\n      }\n      animate();\n\n      window.addEventListener('pointermove', (e) => {\n        targetX = e.clientX;\n        targetY = e.clientY;\n      }, { passive: true });\n\n      window.addEventListener('resize', () => {\n        targetX = window.innerWidth * 0.5;\n        targetY = window.innerHeight * 0.5;\n      });\n    })();\n  </script>\n</div>";
---

<BaseLayout
  title="Services Main | Mitch Chadban"
  description="Design, branding, illustration, SEO and growth marketing services from Mitch Chadban. Pick the service your brand needs and get a quote, no agency layers."
  canonical="https://mitchchadban.com/services-main/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/services-main/' },
    { lang: 'es', href: 'https://mitchchadban.com/servicios-principales/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/services-main/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
