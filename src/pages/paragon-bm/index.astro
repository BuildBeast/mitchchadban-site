---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Creative Direction / Business Design</div>\n      <h1>Paragon BM</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nCreative direction and branding design for Paragon Building Management, developed to balance professionalism, clarity, and a strong, recognisable identity across digital and physical touchpoints.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/Paragon-2.jpg\" alt=\"Paragon BM logo design by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Paragon-3.jpg\" alt=\"Alt Paragon BM logo design by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/PAragon-6.jpg\" alt=\"Paragon BM logo on Facebook\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Paragon-1.jpg\" alt=\"Paragon BM logo on black background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Paragon-4.jpg\" alt=\"Paragon BM Facebook\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Paragon-5.jpg\" alt=\"Paragon BM logo on website\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Paragon Building Management</strong> was a branding project focused on creating a visual identity that felt both professional and distinctive. The aim was to develop a logo and broader brand direction that reflected the quality of service Paragon provides while giving the business a sharper, more confident market presence.\n        </p>\n\n        <p>\nA logo is often the first impression people have of a company, so the identity needed to clearly communicate who Paragon are, what they do, and the level of trust and professionalism they bring to their clients. The direction balanced clean structure with a more considered creative edge, helping the business feel established without becoming generic.\n        </p>\n\n        <p>\nThe final identity has since been applied across a wide range of brand touchpoints, including digital use, vehicles, uniforms, and printed collateral.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Paragon BM</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Creative Direction / Branding / Identity Design</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Building Management</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Applications</div>\n          <div class=\"portfolio-project-ctm__value\">Digital / Vehicles / Uniforms / Print Collateral</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/the-star-hotel/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">The Star Hotel</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/yellow-billy-the-sty/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Yellow Billy &#x26; The Sty</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Paragon BM | Mitch Chadban"
  description="Branding and creative direction for Paragon Building Management. A clean, confident logo and identity applied across digital, vehicles, uniforms and print."
  canonical="https://mitchchadban.com/paragon-bm/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/paragon-bm/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/paragon-bm/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/paragon-bm/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
