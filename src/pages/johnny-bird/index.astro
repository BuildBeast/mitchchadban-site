---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Illustration / Menu Design</div>\n      <h1>Johnny Bird</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nCharacter illustration and menu design created for Johnny Bird — a chicken-focused fast food restaurant in Crow’s Nest, NSW, developed during a major venue makeover.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/G2827810581592435051235892124121/JB-4.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/Y2827810581573988307162182572505/JB-3.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/D2827810581610881795309601675737/JB-5.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/W2827810581555541563088473020889/JB-2.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/I2827810581629328539383311227353/JB-6.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Johnny Bird</strong> is a chicken-based fast food restaurant located in Crow’s Nest, NSW. The project began during a large makeover of the venue, with the brief focused on creating a set of retro Americana-inspired anthropomorphic characters alongside a refreshed menu design.\n        </p>\n\n        <p>\nThe creative direction leaned into playful character illustration and vintage fast-food styling to give the brand a stronger personality and visual presence inside the restaurant environment.\n        </p>\n\n        <p>\nOutside of the original brief, the art direction and overall development of the project were handled entirely by me, shaping the visual tone and direction of the final work.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Johnny Bird</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Illustration / Menu Design / Art Direction</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Fast Food</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Location</div>\n          <div class=\"portfolio-project-ctm__value\">Crow’s Nest, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/W2827810581647775283457020778969/JB-7.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"https://freight.cargo.site/w/1600/i/N2827810581666222027530730330585/JB-8.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://johnnybird.com.au\" rel=\"noopener\" target=\"_blank\">johnnybird.com.au</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/karl-jacobs\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Karl Jacobs</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/monoduo/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">MonoDuo</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Johnny Bird | Mitch Chadban"
  description="Design, SEO and marketing for brands, SaaS companies and service businesses that need sharper websites, stronger content and cleaner growth systems."
  canonical="https://mitchchadban.com/johnny-bird/"
>
