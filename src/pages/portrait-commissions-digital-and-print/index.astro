import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<!--  ============================================================\n     SCHEMA MARKUP — paste inside <head> or via Yoast/RankMath\n     ============================================================  -->\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Service\",\n      \"@id\": \"https://mitchchadban.com/custom-people-portraits/#service\",\n      \"name\": \"Custom People Portraits from Photos\",\n      \"description\": \"Custom illustrated people portraits created from your photos by Mitch Chadban, a designer based in Australia. Styles include clean and modern, bold and fun, and minimal line portrait. Suitable for gifts, couples, families, weddings, and memorial pieces. Delivered as high-resolution digital files.\",\n      \"provider\": {\n        \"@type\": \"Person\",\n        \"name\": \"Mitch Chadban\",\n        \"url\": \"https://mitchchadban.com\",\n        \"address\": {\n          \"@type\": \"PostalAddress\",\n          \"addressCountry\": \"AU\"\n        }\n      },\n      \"areaServed\": {\n        \"@type\": \"Country\",\n        \"name\": \"Australia\"\n      },\n      \"serviceType\": \"Custom Illustrated Portrait\",\n      \"offers\": [\n        {\n          \"@type\": \"Offer\",\n          \"name\": \"Solo Portrait\",\n          \"description\": \"Custom illustrated portrait for one person. Includes high-res digital files (web and print-ready) and one round of revisions.\",\n          \"eligibleRegion\": {\n            \"@type\": \"Country\",\n            \"name\": \"Australia\"\n          }\n        },\n        {\n          \"@type\": \"Offer\",\n          \"name\": \"Couples Portrait\",\n          \"description\": \"Custom illustrated portrait for two people. Balanced composition with print-ready files and one round of revisions.\"\n        },\n        {\n          \"@type\": \"Offer\",\n          \"name\": \"Family or Group Portrait\",\n          \"description\": \"Custom illustrated portrait for three or more people. Consistent style with clean layout and print-ready files.\"\n        }\n      ]\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Can you combine people from different photos into one portrait?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes — this is one of the most common requests, especially for gifts and family portraits where everyone is rarely in the same photo at the same time. Just send the best individual photo of each person and the portrait is composed from there.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Can you add or remove details from the portrait?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes. Clothing colour, small background distractions, and minor features can all be adjusted. The goal is always a clean, flattering portrait — if something in the photo isn't working, it can usually be refined.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How long does a custom portrait take?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Most portraits are completed within 1–2 weeks depending on complexity and current workload. If the portrait is a gift with a hard deadline, mention that upfront and I will confirm whether the timeline is achievable before work begins.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Do you ship physical prints?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"The standard delivery is high-resolution digital files — both web-ready and print-ready formats. For physical prints, I can recommend print options based on your location, or we can organise printing and shipping depending on where you are.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Can you include pets in a people portrait?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Absolutely. Pets are included in family and group portraits without any issue. For a dedicated portrait featuring only a pet, there is a separate Pet Portraits page.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What if I want a portrait style that isn't listed?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Send a reference image or describe what you have in mind. The three listed styles cover most requests, but there is some flexibility to adapt within reason. The goal is always a portrait that suits you and your space.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What kind of photos produce the best portrait?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Well-lit photos with clear faces work best — natural light is ideal. Avoid heavy filters or very low resolution. A few angles or expression options help too. If you're unsure whether a photo will work, send it and I'll let you know before any work starts.\"\n          }\n        }\n      ]\n    },\n    {\n      \"@type\": \"Person\",\n      \"name\": \"Mitch Chadban\",\n      \"url\": \"https://mitchchadban.com\",\n      \"jobTitle\": \"Designer, Illustrator, and SEO Specialist\",\n      \"description\": \"Mitch Chadban is an Australian designer, marketer, and illustrator who creates custom people portraits from photos. Based in Australia, he works with individuals and families on solo, couple, family, and group portrait commissions.\",\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"addressCountry\": \"AU\"\n      }\n    }\n  ]\n}\n</script>\n\n<!--  ============================================================\n     PAGE CONTENT — paste into WordPress page body\n     ============================================================  -->\n\n<div class=\"mc-about\">\n\n  <h1>Custom People Portraits from Photos — Illustrated by a Designer, Made to Keep</h1>\n\n  <p>A custom people portrait is an illustrated artwork created from your photos — designed to sit on your wall, not in a folder. I&#x27;m Mitch Chadban, an Australian designer who creates custom illustrated portraits for individuals, couples, families, and groups. Each portrait is built from your photos, refined until it&#x27;s right, and delivered as high-resolution files ready to print or frame. Most commissions are completed within 1–2 weeks.</p>\n\n  <p>This isn&#x27;t a mass-production service. Every portrait I create is designed from scratch — drawn to your photos, adjusted to your preferences, and finished to a standard I&#x27;d put my name on. Which, for what it&#x27;s worth, I do.</p>\n\n  <!--  ============================================================\n       WHAT YOU GET\n       ============================================================  -->\n\n  <h2>What You Get With Every Commission</h2>\n\n  <p>Every custom portrait commission — regardless of package — includes:</p>\n\n  <ul>\n    <li>a custom illustrated portrait drawn directly from your photos</li>\n    <li>one round of revisions to refine expression, colour, detail, or background</li>\n    <li>high-resolution final files in both web-ready and print-ready format</li>\n    <li>background options: simple solid, colour block, or clean gradient</li>\n    <li>optional name or date text — useful for gifts and milestone pieces</li>\n  </ul>\n\n  <div class=\"img-full-ctm\"><img class=\"zoomable\" src=\"/images/Custom-People-Portraits-Made-From-Your-Photos-office.png\" alt=\"Cheesy stock photo of a person in a \" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"720\"></div>\n\n  <!--  ============================================================\n       PORTRAIT STYLES\n       ============================================================  -->\n\n  <h2>Portrait Styles — Pick Your Vibe</h2>\n\n  <p>Three illustration styles are available, each suited to different spaces and personalities. Not sure which fits? Send a reference image and I can advise before you commit.</p>\n\n  <table class=\"table-ctm\">\n    <thead>\n      <tr>\n        <th>Style</th>\n        <th>What it looks like</th>\n        <th>Best for</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td><strong>Clean + Modern</strong></td>\n        <td>Polished, minimalist, timeless — premium without being cold</td>\n        <td>Home décor, professional gifts, living room art</td>\n      </tr>\n      <tr>\n        <td><strong>Bold + Fun</strong></td>\n        <td>More colour, more personality — energetic and expressive</td>\n        <td>Birthday gifts, celebrations, friend group pieces</td>\n      </tr>\n      <tr>\n        <td><strong>Minimal Line Portrait</strong></td>\n        <td>Simple outline style — subtle, contemporary, unobtrusive</td>\n        <td>Modern interiors, wedding gifts, quiet keepsakes</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <!--  ============================================================\n       OCCASIONS\n       ============================================================  -->\n\n  <h2>What People Commission Portraits For</h2>\n\n  <p>Custom portraits work for almost any occasion where a personal, lasting gift makes more sense than something generic. Here&#x27;s where most commissions come from:</p>\n\n  <h3>Birthday and Christmas Gifts</h3>\n  <p>A portrait is the kind of gift that gets hung on a wall, not put in a drawer. Whether it&#x27;s a solo portrait of someone you love, a couple&#x27;s portrait for a milestone birthday, or a family piece for a parent who has everything — it&#x27;s specific, considered, and genuinely hard to top.</p>\n\n  <h3>Wedding, Engagement, and Anniversary Keepsakes</h3>\n  <p>Couples portraits drawn from a favourite photo — engagement shoot, wedding day, or just a great candid — make a beautiful keepsake or an equally thoughtful gift for a couple you know. I can work from professional photography or casual phone shots.</p>\n\n  <h3>Family Portraits</h3>\n  <p>A family portrait that everyone&#x27;s actually in at the same time, without anyone having to style, coordinate, or argue about location. I can combine photos from different occasions to create one cohesive portrait — useful when family members are spread across states or countries.</p>\n\n  <h3>New Baby Gifts</h3>\n  <p>A portrait of a new arrival — solo, or with parents or siblings — is a meaningful first-week gift that families typically keep for decades. These are some of the most sentimental commissions I work on.</p>\n\n  <h3>Memorial Portraits</h3>\n  <p>I work on memorial portraits with care and take these commissions seriously. A portrait drawn from an older photo, or one that brings a lost family member into a contemporary family piece, is something I do thoughtfully and without rushing.</p>\n\n  <h3>Friend Group and Team Pieces</h3>\n  <p>Group portraits for close friends, sports teams, band members, or work teams — particularly good as a farewell gift, end-of-season piece, or &#x22;we actually did it&#x22; memento.</p>\n\n  <!--  ============================================================\n       HOW IT WORKS\n       ============================================================  -->\n\n  <h2>How the Commission Process Works</h2>\n\n  <h3>Step 1 — Send your photos and details</h3>\n  <p>You send 2–5 photos, tell me who&#x27;s in the portrait, which style you&#x27;d like, whether you want any text added, and your deadline if it&#x27;s a gift. The more context, the better the first draft.</p>\n\n  <h3>Step 2 — I illustrate the portrait</h3>\n  <p>I draw the portrait from your photos. Most first drafts are ready within 5–7 business days. You&#x27;ll receive a preview before anything is finalised.</p>\n\n  <h3>Step 3 — We refine it</h3>\n  <p>One round of revisions is included. Expression adjustments, hair detail, clothing colour, background changes — we get it to exactly where it needs to be.</p>\n\n  <h3>Step 4 — You receive the final files</h3>\n  <p>High-res files are delivered digitally — web-ready for sharing and print-ready for framing. If you need a physical print organised, I can point you toward the right options.</p>\n\n  <div class=\"img-full-ctm\">\n    <img class=\"zoomable\" src=\"/images/Custom-People-Portraits-Made-From-Your-Photos-wow.png\" alt=\"Family portrait mission control — Cheesy stock photo of a person in a command center setup with multiple monitors showing blurred portrait thumbnails (no readable text), holding a printed custom portrait draft. They look extremely focused like launching a rocket. Overlit, staged, slightly uncanny AI vibe, wide banner crop, no logos.\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"720\">\n  </div>\n\n  <!--  ============================================================\n       PACKAGES\n       ============================================================  -->\n\n  <h2>Commission Packages</h2>\n\n  <p>Three packages based on how many people are in the portrait. All include the same deliverables — files, revisions, and background options.</p>\n\n  <table class=\"table-ctm\">\n    <thead>\n      <tr>\n        <th>Package</th>\n        <th>Who it&#x27;s for</th>\n        <th>What&#x27;s included</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td><strong>Option A — Solo Portrait</strong></td>\n        <td>1 person</td>\n        <td>High-res digital files (web + print-ready), background choice, 1 revision</td>\n      </tr>\n      <tr>\n        <td><strong>Option B — Couples Portrait</strong></td>\n        <td>2 people</td>\n        <td>Balanced two-person composition, print-ready files with sizing options, 1 revision</td>\n      </tr>\n      <tr>\n        <td><strong>Option C — Family / Group Portrait</strong></td>\n        <td>3 or more people</td>\n        <td>Consistent multi-person layout, print-ready files, 1 revision — can combine separate photos</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <p>Not sure which option suits your situation? Send an enquiry with who&#x27;s in the portrait and any deadline — I&#x27;ll confirm the best approach and turnaround time before you commit to anything.</p>\n\n  <!--  ============================================================\n       PHOTO TIPS\n       ============================================================  -->\n\n  <h2>How to Send Photos That Give You the Best Result</h2>\n\n  <p>Portrait quality is directly related to photo quality — but you don&#x27;t need professional shots. These guidelines cover what actually matters:</p>\n\n  <ul>\n    <li><strong>Lighting:</strong> natural light works best — near a window, outdoors, or any evenly lit environment. Avoid harsh flash or heavy shadows across the face.</li>\n    <li><strong>Resolution:</strong> a standard modern phone photo is fine. Screenshots, heavily cropped images, or very old low-res files can limit detail.</li>\n    <li><strong>Filters:</strong> send the original where possible. Heavy filters change skin tone, eye colour, and facial proportions in ways that make accurate illustration harder.</li>\n    <li><strong>Angles:</strong> a slight turn is fine, but full side-profile shots make facial features harder to capture accurately. Front-facing or three-quarter angle is ideal.</li>\n    <li><strong>Quantity:</strong> 2–5 photos gives options — useful if one has better hair, another has a better expression, and so on.</li>\n  </ul>\n\n  <p>If you&#x27;re not confident about what to send, send what you have. I&#x27;ll review the photos before work starts and flag anything that might affect the outcome.</p>\n\n  <!--  ============================================================\n       SOCIAL PROOF\n       ============================================================  -->\n\n  <h2>What People Say</h2>\n\n  <p><em>&#x22;I ordered a family portrait combining three separate photos — my parents, my sister&#x27;s family, and mine. Mitch pulled them into one piece that actually looked like we were all there at the same time. We had it printed at A2 and it&#x27;s the first thing people comment on when they visit.&#x22; — Sarah M., Sydney</em></p>\n\n  <p><em>&#x22;Got a couples portrait done as a wedding anniversary gift. The line portrait style was exactly what I was after — subtle enough to suit the room but detailed enough to actually look like them. Whole process was easy and the files came back fast.&#x22; — James T., Melbourne</em></p>\n\n  <p><em>&#x22;I needed a memorial portrait of my dad drawn from an older photo. Mitch was respectful and careful with it — came back better than I expected and the revision process was easy. Really glad I went with a real designer rather than an automated service.&#x22; — Karen L., Brisbane</em></p>\n\n  <!--  ============================================================\n       FAQ\n       ============================================================  -->\n\n  <h2>Frequently Asked Questions</h2>\n\n  <h3>Can you combine people from different photos into one portrait?</h3>\n  <p>Yes — this is one of the most common requests, especially for family portraits where everyone is rarely in the same photo. Send the best individual shot of each person and I&#x27;ll compose them into one cohesive portrait.</p>\n\n  <h3>Can you add or remove details from the reference photo?</h3>\n  <p>Yes. Clothing colour, small background distractions, and minor features can all be adjusted during the revision round. The goal is always a clean, flattering portrait — if something in the photo isn&#x27;t working for the illustration, it can be refined.</p>\n\n  <h3>How long does a custom portrait take?</h3>\n  <p>Most portraits are completed within 1–2 weeks depending on complexity and current workload. If there&#x27;s a hard deadline — a birthday, a wedding, Christmas — mention it upfront. I&#x27;ll confirm whether the timeline is achievable before any work starts.</p>\n\n  <h3>Do you ship physical prints?</h3>\n  <p>Standard delivery is high-resolution digital files — web-ready and print-ready. For physical prints, I can recommend quality print options based on your location, or we can organise printing and delivery depending on where you are.</p>\n\n  <h3>Can you include pets in a people portrait?</h3>\n  <p>Absolutely. Pets are included in family and group commissions without any issue. If you want a dedicated portrait for a pet, there&#x27;s a separate Pet Portraits page for that.</p>\n\n  <h3>What if I want a style that isn&#x27;t one of the three listed?</h3>\n  <p>Send a reference image or describe what you have in mind. The three styles cover most requests, but there is some flexibility to adapt. The goal is always a portrait that suits you and your space — if what you&#x27;re imagining is workable, we&#x27;ll find a way to get there.</p>\n\n  <h3>What kind of photos produce the best portrait?</h3>\n  <p>Well-lit photos with clear faces work best — natural light is ideal. Avoid heavy filters or very low-resolution images. A few angles or expression options help. If you&#x27;re unsure whether a photo will work, send it and I&#x27;ll review before work begins.</p>\n\n  <!--  ============================================================\n       CTA\n       ============================================================  -->\n\n  <h2>Ready to Commission a Custom Portrait?</h2>\n\n  <p>Send an enquiry with the following and I&#x27;ll come back to you with next steps, timeline, and pricing:</p>\n\n  <ul>\n    <li>how many people (or people and pets) are in the portrait</li>\n    <li>your preferred style — or a reference if you&#x27;re not sure</li>\n    <li>your deadline, if it&#x27;s a gift</li>\n    <li>2–5 photos when you&#x27;re ready</li>\n  </ul>\n\n  <p>Button: Commission a Custom Portrait<br />Small link: Prefer email? Contact Mitch</p>\n<br />\n  <br />\n</div>";
