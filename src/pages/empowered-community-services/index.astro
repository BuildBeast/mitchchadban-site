---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Community / Ongoing Creative Support</div>\n      <h1>Empowered Community Services</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nBranding and ongoing creative work for Empowered Community Services, building a warm, community-focused identity across signage, print, vehicles, merchandise, murals, and digital touchpoints.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n       <img class=\"zoomable\" src=\"/images/ECS-1.jpg\" alt=\"Empowered Community Services branding application hero image\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-12.jpg\" alt=\"Empowered Community Services branded community support material 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n       <img class=\"zoomable\" src=\"/images/ECS-4.jpg\" alt=\"Empowered Community Services branded community support material 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-11.jpg\" alt=\"Empowered Community Services branded community support material 3\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-6.jpg\" alt=\"Empowered Community Services branded community support material 4\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-5.jpg\" alt=\"Empowered Community Services branding application 5\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-9.jpg\" alt=\"Empowered Community Services branding application 6\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-8.jpg\" alt=\"Empowered Community Services branding application 7\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Empowered Community Services</strong> was founded in 2017 and delivers high-quality, individualised support under the NDIS, helping people with disability build capacity, independence, and stronger participation in their communities.\n        </p>\n\n        <p>\nI have worked with Empowered since its inception, initially developing the branding and then expanding that system as the organisation grew. Over time, the creative work has extended across signage, banners, merchandise, vehicle wraps, brochures, murals, and other brand applications.\n        </p>\n\n        <p>\nThe goal throughout the project was to build a brand that felt warm, welcoming, and reflective of the company’s values and strong community involvement. That relationship has continued over the years, and I still handle a large proportion of Empowered’s creative work today.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Project</div>\n          <div class=\"portfolio-project-ctm__value\">Empowered Community Services</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Scope</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Signage / Print / Vehicle Wraps / Merchandise / Murals</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Industry</div>\n          <div class=\"portfolio-project-ctm__value\">Community Services / NDIS</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Relationship</div>\n          <div class=\"portfolio-project-ctm__value\">Ongoing Creative Support Since 2017</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-17.jpg\" alt=\"Empowered Community Services branded signage or mural design 8\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-15.jpg\" alt=\"Empowered Community Services branded signage or mural design 9\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-19.jpg\" alt=\"Empowered Community Services branded signage or mural design 10\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-18.jpg\" alt=\"Empowered Community Services branded signage or mural design 11\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-14.jpg\" alt=\"Empowered Community Services branded signage or mural design 12\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-16.jpg\" alt=\"Empowered Community Services branded signage or mural design 13\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/ECS-2.jpg\" alt=\"Empowered Community Services branding rollout example 14\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/ECS-3.jpg\" alt=\"Empowered Community Services branding rollout example 15\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__video portfolio-project-ctm__video--full\">\n      <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/Lmx7ymffzwc\" title=\"Empowered Community Services video\">\n      </iframe>\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://empoweredcommunityservices.com\" rel=\"noopener\" target=\"_blank\">empoweredcommunityservices.com</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/portfolio-1/\">Back to Portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/newy-fried-chicken/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Previous Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Newy Fried Chicken</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/archive/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Next Project</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Archive</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  title="Empowered Community Services | Mitch Chadban"
  description="Branding and ongoing creative for Empowered Community Services, an NDIS provider: signage, vehicle wraps, print, merch and murals."
  canonical="https://mitchchadban.com/empowered-community-services/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
