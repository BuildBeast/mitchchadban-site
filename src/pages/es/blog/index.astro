const tagButtonsHtml = tags
  .map((tag) => `<button class="blog-ctm__tagbtn" data-tag="${tag}" type="button">${tag}</button>`)
  .join('\n        ');

const postCardsHtml = posts
  .map(
    (post) => `<a class="post-ctm c2-card" href="${post.href}" aria-label="Leer: ${post.title}">
        <div class="post-ctm__top">
          <h2 class="post-ctm__h">${post.title}</h2>
          <div class="post-ctm__meta">
            ${post.tags.map((tag) => `<span class="post-ctm__pill">${tag}</span>`).join('')}
          </div>
        </div>
        <p class="post-ctm__p">${post.excerpt}</p>
        <span class="post-ctm__link">
          <span class="post-ctm__read">Leer más</span><span class="post-ctm__arrow">↗</span>
        </span>
      </a>`
  )
  .join('\n\n      ');

const pageContent = `<!--  ARCHIVO DEL BLOG (ESPAÑOL — REFLEJA /blogs-resources/)  -->
<section class="blog-ctm portfolio-ctm" id="blogArchive">
  <div class="portfolio-ctm__inner" style="padding-top:72px;">

    <div class="blog-ctm__head portfolio-ctm__head" style="margin-top:0;">
      <h1 style="margin:0 0 18px; font-size:clamp(78px,10vw,132px); line-height:0.9;">Blog</h1>
      <p class="blog-ctm__sub" style="margin:0;">Elige un tema. Encuentra el manual. Avanza más rápido.</p>
    </div>

    <div aria-label="Filtros del blog" class="blog-ctm__controls">
      <div aria-label="Filtrar por etiqueta" class="blog-ctm__tags" id="blogTags">
        <button class="blog-ctm__tagbtn is-active" data-tag="All" type="button">Todos</button>
        ${tagButtonsHtml}
      </div>
    </div>

    <div class="blog-ctm__list" id="blogList">
      ${postCardsHtml}

      <div class="blog-ctm__empty" id="blogEmpty" style="display:none;">No hay artículos para ese filtro.</div>
    </div>

    <div class="blog-ctm__more">
      <button class="blog-ctm__loadBtn" id="blogLoadMore" style="display: none;" type="button">
        Cargar más
      </button>
    </div>

  </div>

  <script>
    (function () {
      function initBlogArchive() {
        const $root = document.getElementById("blogArchive");
        const $list = document.getElementById("blogList");
        const $tags = document.getElementById("blogTags");
        const $moreBtn = document.getElementById("blogLoadMore");
        const $empty = document.getElementById("blogEmpty");

        if (!$root || !$list || !$tags || !$moreBtn || !$empty) return;
        if ($root.__blogBound) return;
        $root.__blogBound = true;

        const PAGE_SIZE = 6;
        let activeTag = "All";
        let visibleCount = PAGE_SIZE;

        const posts = Array.from($list.querySelectorAll(".post-ctm")).map((card) => {
          const tags = Array.from(card.querySelectorAll(".post-ctm__pill"))
            .map((pill) => (pill.textContent || "").trim())
            .filter(Boolean);

          return { card, tags };
        });

        function syncActiveTag() {
          $tags.querySelectorAll("[data-tag]").forEach((btn) => {
            const tag = btn.getAttribute("data-tag") || "";
            btn.classList.toggle("is-active", tag === activeTag);
          });
        }

        function getFilteredPosts() {
          if (activeTag === "All") return posts;
          return posts.filter((post) => post.tags.includes(activeTag));
        }

        function renderPosts() {
          const filtered = getFilteredPosts();
          const shown = filtered.slice(0, visibleCount);

          posts.forEach((post) => {
            post.card.style.display = "none";
          });

          if (!shown.length) {
            $empty.style.display = "";
            $moreBtn.style.display = "none";
            return;
          }

          $empty.style.display = "none";

          shown.forEach((post) => {
            post.card.style.display = "";
          });

          $moreBtn.style.display = visibleCount >= filtered.length ? "none" : "inline-flex";
        }

        $tags.addEventListener("click", function (e) {
          const btn = e.target.closest("[data-tag]");
          if (!btn) return;

          e.preventDefault();
          e.stopPropagation();

          activeTag = btn.getAttribute("data-tag") || "All";
          visibleCount = PAGE_SIZE;

          syncActiveTag();
          renderPosts();
        });

        $moreBtn.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();

          visibleCount += PAGE_SIZE;
          renderPosts();
        });

        syncActiveTag();
        renderPosts();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initBlogArchive);
      } else {
        initBlogArchive();
      }
    })();
  </script>
  <br />
  <br />
</section>`;
