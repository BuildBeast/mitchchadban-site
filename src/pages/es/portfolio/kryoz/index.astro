---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Ilustración / Apparel / Colaboración</div>\n      <h1>Kryoz Gardening</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nUna ilustración espiritual y psicodélica creada para Kryoz Gardening: una colección limitada de apparel desarrollada con dirección creativa de Ed en Revolt Enterprises.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/Kryoz-1.jpg\" alt=\"Kryoz on a phone wearing a shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/Kryoz-4.jpg\" alt=\"Kryoz shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/Kryoz-2.jpg\" alt=\"Close up of Kryoz shirt designed by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/Kryoz-3.jpg\" alt=\"Illustartion for a t-shirt for Kryoz\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Kryoz Gardening</strong> se creó como una pieza de ilustración atrevida y surrealista para una colección limitada de apparel. La dirección visual se apoyó en referencias espirituales, psicodélicas y lúdicas inspiradas en el jardín, dando al lanzamiento una identidad fuerte, distintiva y con carácter de colección.\n        </p>\n\n        <p>\nEl proyecto se desarrolló en colaboración con Ed, de Revolt Enterprises, que lideró la dirección creativa de la colección. La ilustración final se aplicó a todo el lanzamiento de apparel y ayudó a definir el tono general del drop.\n        </p>\n\n        <p>\nDesde entonces, la colección se lanzó y se agotó.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Kryoz Gardening</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Ilustración / Gráfica para apparel</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Dirección creativa</div>\n          <div class=\"portfolio-project-ctm__value\">Ed / Revolt Enterprises</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Resultado</div>\n          <div class=\"portfolio-project-ctm__value\">Lanzada + agotada</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Portfolio</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/pinos-restaurant/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Pino’s Restaurant</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Kryoz Gardening | Portfolio en Español | Mitch Chadban"
  description="Ilustración espiritual y psicodélica para Kryoz Gardening: una colección limitada de apparel desarrollada con dirección creativa de Revolt Enterprises."
  canonical="https://mitchchadban.com/es/portfolio/kryoz/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/kryoz/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/kryoz/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/kryoz/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
