---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Dirección creativa / ilustración</div>\n      <h1>The Star Hotel</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nDirección creativa e ilustración para una serie de carteles creada para The Star Hotel de Newcastle, pensada para captar la atmósfera tipo lounge del venue y la energía ecléctica y juguetona de sus eventos de jazz.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Star-2.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Star-3.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Star-5.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Star-4.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Star-1.jpg\" alt=\"abstract geometroc posters for the star\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          El proyecto de <strong>The Star Hotel</strong> giró en torno a una serie de carteles creada para promocionar los eventos de jazz del venue. El enfoque creativo equilibró atmósfera y energía para reflejar tanto el carácter relajado del espacio como la naturaleza expresiva y ecléctica de la música.\n        </p>\n\n        <p>\nLa dirección visual apostó por la ilustración y una composición contundente para crear carteles con identidad, carácter y un vínculo claro con el espíritu de los eventos, en lugar de parecer promo genérica de venue.\n        </p>\n\n        <p>\nEl resultado fue una serie de piezas promocionales enfocadas en hospitality, diseñadas para sentirse vivas, memorables y visualmente integradas en la escena musical local de Newcastle.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">The Star Hotel</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Dirección creativa / ilustración / diseño de carteles</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Eventos</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/pinos-restaurant/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Pino’s Restaurant</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/paragon-bm/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Paragon BM</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="The Star Hotel | Portfolio en Español | Mitch Chadban"
  description="Dirección creativa e ilustración para la serie de carteles de The Star Hotel, pensada para capturar la atmósfera lounge y la energía de sus eventos de jazz."
  canonical="https://mitchchadban.com/es/portfolio/the-star-hotel/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/the-star-hotel/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/the-star-hotel/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/the-star-hotel/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
