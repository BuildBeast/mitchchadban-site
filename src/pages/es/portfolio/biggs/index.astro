---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm portfolio-project-ctm--biggs\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Hospitality / Diseño de identidad</div>\n      <h1>Biggs Coffee</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nBranding desarrollado para el lanzamiento de Biggs Coffee, una cafetería de Hamilton situada cerca de la estación y con una identidad inspirada en el infame ladrón de trenes británico Ronald Biggs.\n      </p>\n    </div>\n\n    <hr />\n\n    <!--  HERO  -->\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/Biggs7.jpg\" alt=\"Bigg logo on the biggs app\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <!--  SUPPORTING 2-UP  -->\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-17.jpg\" alt=\"Biggs logo on white background\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-12.jpg\" alt=\"Biggs menu pamphlet design\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Biggs Coffee</strong> fue un proyecto de branding desarrollado para el lanzamiento de una nueva cafetería en Hamilton. La ubicación del local, cerca de una estación de tren, influyó de forma directa en el concepto creativo de la identidad.\n        </p>\n\n        <p>\nLos propietarios lideraron la dirección de arte del proyecto y posicionaron la cafetería alrededor de la figura de Ronald Biggs, el infame ladrón de trenes británico. El brief se centró en construir una serie de elementos de branding escalables que pudieran aplicarse con coherencia en el local y en sus materiales de marketing.\n        </p>\n\n        <p>\nEl concepto central del logotipo hace referencia al gesto de la mano por el que Biggs era conocido, creando un símbolo distintivo y memorable que conecta la identidad de la cafetería con la temática ferroviaria, manteniéndose juguetón, reconocible y fácil de aplicar en señalética, menús, apparel y otros puntos de contacto de marca.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Biggs Coffee</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Diseño de identidad / Sistema visual</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Cafetería</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Hamilton, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <!--  DETAIL ROW  -->\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-3.jpg\" alt=\"Biggs store front image 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-14.jpg\" alt=\"Biggs logo on a blurry background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Biggs-4.jpg\" alt=\"Biggs menu board\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <!--  FINAL 2-UP  -->\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-13.jpg\" alt=\"Biggs logo on a blurry background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Biggs-2.jpg\" alt=\"Biggs store front image 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/empowered-community-services/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Empowered Community Services</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Portfolio</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Biggs Coffee | Portfolio en Español | Mitch Chadban"
  description="Branding para el lanzamiento de Biggs Coffee: una identidad escalable para una cafetería de Hamilton inspirada en el universo ferroviario de Ronald Biggs."
  canonical="https://mitchchadban.com/es/portfolio/biggs/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/biggs/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/biggs/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/biggs/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
