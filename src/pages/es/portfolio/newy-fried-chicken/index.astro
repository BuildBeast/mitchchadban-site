---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Art Dirección / ilustración</div>\n      <h1>Newy Fried Chicken</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nDirección de arte, ilustración y trabajo de layout creados para el local de fried chicken favorito de Newcastle, desarrollando activos de marca, carteles y merchandising con un estilo de personaje retro y moderno.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-10.jpg\" alt=\"Newy Fried Chicken illustration and poster artwork 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-9.jpg\" alt=\"Newy Fried Chicken illustration and poster artwork 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-11.jpg\" alt=\"Newy Fried Chicken illustration and poster artwork 3\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-14.jpg\" alt=\"Newy Fried Chicken mascot-style brand artwork 4\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-15.jpg\" alt=\"Newy Fried Chicken mascot-style brand artwork 5\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-13.jpg\" alt=\"Newy Fried Chicken mascot-style brand artwork 6\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-12.jpg\" alt=\"Newy Fried Chicken mascot-style brand artwork 7\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Newy Fried Chicken</strong> es un clásico de Newcastle, conocido por su personalidad marcada y por una base de seguidores muy fiel. El proyecto consistió en desarrollar una gama de activos visuales que incluían ilustración, diseño de layouts, carteles y merchandising.\n        </p>\n\n        <p>\nLa dirección creativa se apoyó con fuerza en un diseño de personajes juguetón, inspirado en las mascotas retro antropomórficas clásicas, actualizado con un estilo gráfico moderno, energético y acogedor.\n        </p>\n\n        <p>\nA lo largo de los distintos proyectos, el objetivo fue crear trabajo que se sintiera divertido, distintivo y reconocible al instante, manteniendo a la vez la flexibilidad suficiente para aplicarse en carteles, merchandising y otros puntos de contacto de marca.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Newy Fried Chicken</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Art Dirección / ilustración / Posters / merchandising</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Fast food</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-8.jpg\" alt=\"Newy Fried Chicken merchandise or poster artwork 8\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-7.jpg\" alt=\"Newy Fried Chicken merchandise or poster artwork 9\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-6.jpg\" alt=\"Newy Fried Chicken merchandise or poster artwork 10\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-1.jpg\" alt=\"Newy Fried Chicken brand illustration 11\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-2.jpg\" alt=\"Newy Fried Chicken brand illustration 12\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-3.jpg\" alt=\"Newy Fried Chicken brand illustration 13\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/NFC-4.jpg\" alt=\"Newy Fried Chicken brand illustration 14\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/NFC-5.jpg\" alt=\"Newy Fried Chicken brand illustration 15\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/NFC-g.jpg\" alt=\"Newy Fried Chicken illustrated brand graphic 16\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/NFC-gg.jpg\" alt=\"Newy Fried Chicken illustrated brand graphic 17\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://newyfriedchicken.com\" rel=\"noopener\" target=\"_blank\">newyfriedchicken.com</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/monoduo/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">MonoDuo</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/empowered-community-services/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Empowered Community Services</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Newy Fried Chicken | Portfolio en Español | Mitch Chadban"
  description="Dirección de arte, ilustración y piezas visuales para Newy Fried Chicken: posters, merchandising y activos de marca con un estilo retro moderno."
  canonical="https://mitchchadban.com/es/portfolio/newy-fried-chicken/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/newy-fried-chicken/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/newy-fried-chicken/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/newy-fried-chicken/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
