---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Ilustración / Diseño de menú</div>\n      <h1>Johnny Bird</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nIlustración de personaje y diseño de menú creados para Johnny Bird, un restaurante de fast food especializado en pollo en Crow’s Nest, NSW, desarrollado durante una gran reforma del local.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/JB-4.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 1\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/JB-3.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 2\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/JB-5.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 3\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/JB-2.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 4\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/JB-6.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 5\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Johnny Bird</strong> es un restaurante de fast food especializado en pollo, situado en Crow’s Nest, NSW. El proyecto arrancó durante una gran reforma del local, con un brief centrado en crear una serie de personajes antropomórficos inspirados en la estética retro americana junto con un rediseño del menú.\n        </p>\n\n        <p>\nLa dirección creativa apostó por una ilustración de personaje juguetona y una estética vintage de fast food para dar a la marca más personalidad y una presencia visual más fuerte dentro del entorno del restaurante.\n        </p>\n\n        <p>\nMás allá del brief original, la dirección de arte y el desarrollo global del proyecto estuvieron completamente en mis manos, marcando el tono visual y la dirección del trabajo final.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Johnny Bird</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">ilustración / diseño de menú / dirección de arte</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality / Fast food</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Crow’s Nest, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/JB-7.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 6\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/JB-8.jpg\" alt=\"Johnny Bird character illustration and menu design artwork 7\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://johnnybird.com.au\" rel=\"noopener\" target=\"_blank\">johnnybird.com.au</a>\n    </div>\n<br />\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/karl-jacobs/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Karl Jacobs</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/monoduo/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">MonoDuo</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Johnny Bird | Portfolio en Español | Mitch Chadban"
  description="Ilustración de personaje y diseño de menú para Johnny Bird: una marca de fast food en Crow’s Nest desarrollada durante una gran reforma del local."
  canonical="https://mitchchadban.com/es/portfolio/johnny-bird/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/johnny-bird/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/johnny-bird/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/johnny-bird/' }
  ]}
>
  <Fragment set:html={pageContent} />
