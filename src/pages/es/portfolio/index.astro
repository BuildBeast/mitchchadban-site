---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const projects = [
  { year: '2026', title: 'Tribal Habits', code: 'COD.MC00', type: 'SEO / Content Marketing / AEO', href: '/tribal-habits/' },
  { year: '2026', title: 'Kryoz Gardening', code: 'COD.MC01', type: 'Branding / Web / Servicios Locales', href: '/kryoz/' },
  { year: '2026', title: 'Pino’s Restaurant', code: 'COD.MC02', type: 'Hospitality / Branding / Marketing', href: '/pinos-restaurant/' },
  { year: '2026', title: 'The Star Hotel', code: 'COD.MC03', type: 'Hospitality / Diseño / Materiales', href: '/the-star-hotel/' },
  { year: '2025', title: 'Paragon BM', code: 'COD.MC04', type: 'Branding / Diseño de Negocio', href: '/paragon-bm/' },
  { year: '2025', title: 'Yellow Billy & The Sty', code: 'COD.MC05', type: 'Hospitality / Branding / Creatividad', href: '/yellow-billy-the-sty/' },
  { year: '2025', title: 'Karl Jacobs', code: 'COD.MC06', type: 'Branding / Diseño Digital', href: '/karl-jacobs/' },
  { year: '2025', title: 'Johnny Bird', code: 'COD.MC07', type: 'Branding / Activos de Marketing', href: '/johnny-bird/' },
  { year: '2025', title: 'MonoDuo', code: 'COD.MC08', type: 'Identidad / Sistema de Diseño', href: '/monoduo/' },
  { year: '2024', title: 'Newy Fried Chicken', code: 'COD.MC09', type: 'Hospitality / Marca / Diseño de Campaña', href: '/newy-fried-chicken/' },
  { year: '2024', title: 'Empowered Community Services', code: 'COD.MC10', type: 'Comunidad / Web / Apoyo de Marca', href: '/empowered-community-services/' },
  { year: '2024', title: 'Biggs', code: 'COD.MC11', type: 'Branding / Trabajo Creativo', href: '/biggs/' },
  { year: 'Varios', title: 'Various Posters', code: 'COD.MC12', type: 'Carteles / Experimental / Trabajo Visual', href: '/various-posters/' }
];
---

<BaseLayout
  lang="es"
  title="Portfolio en Español | Mitch Chadban"
  description="Trabajo seleccionado de Mitch Chadban: branding, webs, SEO, marketing y proyectos de hospitality en una experiencia de portfolio en español."
  canonical="https://mitchchadban.com/es/portfolio/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/portfolio-1/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/portfolio-1/' },
  ]}
>
  <div class="portfolio-ctm">
    <div class="portfolio-ctm__inner">
      <div class="portfolio-ctm__head">
        <h1>Trabajo Seleccionado</h1>
        <p>
          Diseño de marca, webs, SEO, campañas de marketing, proyectos de hospitality, cartelería y diseño digital en trabajo para clientes, venues, organizaciones comunitarias y sistemas visuales.
        </p>
      </div>

      <table class="portfolio-ctm__table">
        <tbody>
          {projects.map((project) => (
            <tr>
              <td class="portfolio-ctm__year">{project.year}</td>
              <td class="portfolio-ctm__project">
                <span>{project.title}</span>
                <a class="portfolio-ctm__english-link" href={project.href} lang="en">Ver caso en inglés</a>
                <span>{project.code}</span>
              </td>
              <td class="portfolio-ctm__type">{project.type}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="service-ctm__body" style="padding: 32px 0 0;">
        <p>Si quieres ver cómo conecto diseño, SEO y marketing con una ejecución más clara, te enseño los proyectos adecuados y el contexto detrás del trabajo.</p>
        <a href="/contacto/"><div class="custom-btn"><b>Hablar sobre tu proyecto</b></div></a>
      </div>
    </div>
  </div>
</BaseLayout>
