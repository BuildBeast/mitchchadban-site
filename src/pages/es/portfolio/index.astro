---

<BaseLayout
  lang="es"
  title="Portfolio en Español | Mitch Chadban"
  description="Trabajo seleccionado de Mitch Chadban: branding, webs, SEO, marketing y proyectos de hospitality en una experiencia de portfolio en español."
  canonical="https://mitchchadban.com/es/portfolio/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/portfolio-1/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/portfolio-1/' },
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
