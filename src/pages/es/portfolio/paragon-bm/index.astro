---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Dirección creativa / diseño de negocio</div>\n      <h1>Paragon BM</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nDirección creativa y diseño de branding para Paragon Gestión de edificios, desarrollado para equilibrar profesionalidad, claridad y una identidad fuerte y reconocible en puntos de contacto físicos y digitales.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/Paragon-2.jpg\" alt=\"Paragon BM logo design by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Paragon-3.jpg\" alt=\"Alt Paragon BM logo design by Mitch Chadban\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/PAragon-6.jpg\" alt=\"Paragon BM logo on Facebook\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Paragon-1.jpg\" alt=\"Paragon BM logo on black background\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Paragon-4.jpg\" alt=\"Paragon BM Facebook\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Paragon-5.jpg\" alt=\"Paragon BM logo on website\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Paragon Gestión de edificios</strong> fue un proyecto de branding centrado en crear una identidad visual que se sintiera a la vez profesional y distintiva. El objetivo era desarrollar un logotipo y una dirección de marca más amplia que reflejaran la calidad del servicio de Paragon y, al mismo tiempo, dieran al negocio una presencia de mercado más sólida y segura.\n        </p>\n\n        <p>\nUn logotipo suele ser la primera impresión que la gente tiene de una empresa, así que la identidad debía comunicar con claridad quién es Paragon, qué hace y el nivel de confianza y profesionalidad que transmite a sus clientes. La dirección equilibró una estructura limpia con un punto creativo más pensado, ayudando a que el negocio se sintiera consolidado sin volverse genérico.\n        </p>\n\n        <p>\nDesde entonces, la identidad final se ha aplicado en una amplia variedad de puntos de contacto de marca, incluidos soportes digitales, vehículos, uniformes y material impreso.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Paragon BM</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Dirección creativa / Branding / diseño de identidad</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Gestión de edificios</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Aplicaciones</div>\n          <div class=\"portfolio-project-ctm__value\">Digital / Vehículos / Uniformes / Material impreso</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/biggs/\">Ver proyecto de marca</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/empowered-community-services/\">Ver proyecto relacionado</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/kryoz/\">Ver trabajo visual</a></li>\n      </ul>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/the-star-hotel/\">\n          <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n          <span class=\"portfolio-project-ctm__nav-title\">The Star Hotel</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/yellow-billy-the-sty/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Yellow Billy & The Sty</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Paragon BM | Portfolio en Español | Mitch Chadban"
  description="Dirección creativa y branding para Paragon BM, con una identidad clara y reconocible en soportes físicos y digitales."
  canonical="https://mitchchadban.com/es/portfolio/paragon-bm/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/paragon-bm/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/paragon-bm/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/paragon-bm/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
