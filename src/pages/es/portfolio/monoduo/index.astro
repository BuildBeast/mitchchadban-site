---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Diseño para festivales / Activos de campaña</div>\n      <h1>MonoDuo</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nElementos de branding y activos promocionales creados para MonoDuo Music and Arts Festival, un proyecto de festival en su año de lanzamiento presentado por Palace y Lake Macquarie City Council.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__video portfolio-project-ctm__video--full\">\n      <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/JYZLJCbkKJw\" title=\"MonoDuo video\">\n      </iframe>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/MD-9.jpg\" alt=\"MonoDuo festival branding hero artwork\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n<img class=\"zoomable\" src=\"/images/MD-3.jpg\" alt=\"MonoDuo festival branding asset 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\"></div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/MD-2.jpg\" alt=\"MonoDuo festival branding asset 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/MD-5.jpg\" alt=\"MonoDuo festival branding asset 3\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/MD-6.jpg\" alt=\"MonoDuo festival branding asset 4\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/MD-7.jpg\" alt=\"MonoDuo festival branding asset 5\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/MD-8.jpg\" alt=\"MonoDuo festival branding asset 6\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>MonoDuo Music and Arts Festival</strong> fue un proyecto de festival en su año de lanzamiento, desarrollado con Palace y Lake Macquarie City Council. El encargo incluía crear los elementos centrales de marca y todo el material promocional necesario, desde carteles y banners hasta piezas para artistas y activos de vídeo.\n        </p>\n\n        <p>\nEl festival se celebra en Speers Point Park, junto al lago, lo que dio al proyecto un contexto ambiental y atmosférico muy fuerte. La dirección visual se construyó alrededor del contraste entre el filo industrial de la música techno y la belleza orgánica del paisaje que lo rodea.\n        </p>\n\n        <p>\nLa identidad resultante buscó sentirse impactante, contemporánea y conectada con el lugar, ayudando a construir una estética memorable para el primer año del festival tanto en soportes digitales como físicos.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">MonoDuo Music and Arts Festival</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Carteles / Banners / Piezas de artistas / Activos de vídeo</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Colaboradores</div>\n          <div class=\"portfolio-project-ctm__value\">Palace / Lake Macquarie City Council</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Speers Point Park, Lake Macquarie</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n      <img class=\"zoomable\" src=\"/images/MD-15.jpg\" alt=\"MonoDuo poster or campaign artwork 7\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\"> \n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n<img class=\"zoomable\" src=\"/images/MD-14.jpg\" alt=\"MonoDuo poster or campaign artwork 8\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\"></div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/MD-12.jpg\" alt=\"MonoDuo festival campaign artwork 9\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://arts.lakemac.com.au\" rel=\"noopener\" target=\"_blank\">arts.lakemac.com.au</a>\n    </div>\n<br />\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/johnny-bird/\">Ver proyecto de ilustración</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/karl-jacobs/\">Ver proyecto relacionado</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/various-posters/\">Ver trabajo de cartelería</a></li>\n      </ul>\n    </div>\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/johnny-bird/\">\n          <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n          <span class=\"portfolio-project-ctm__nav-title\">Johnny Bird</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/newy-fried-chicken/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Newy Fried Chicken</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="MonoDuo | Portfolio en Español | Mitch Chadban"
  description="Branding y activos promocionales para MonoDuo Music and Arts Festival, desde carteles hasta piezas para artistas."
  canonical="https://mitchchadban.com/es/portfolio/monoduo/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/monoduo/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/monoduo/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/monoduo/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
