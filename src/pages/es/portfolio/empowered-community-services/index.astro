---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Branding / Comunidad / Soporte creativo continuo</div>\n      <h1>Empowered Community Services</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nBranding y trabajo creativo continuo para Empowered Community Services, construyendo una identidad cálida y centrada en la comunidad a través de señalética, impresión, vehículos, merchandising, murales y puntos de contacto digitales.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n       <img class=\"zoomable\" src=\"/images/ECS-1.jpg\" alt=\"Empowered Community Services branding application hero image\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery4\">\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-12.jpg\" alt=\"Empowered Community Services branded community support material 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n       <img class=\"zoomable\" src=\"/images/ECS-4.jpg\" alt=\"Empowered Community Services branded community support material 2\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-11.jpg\" alt=\"Empowered Community Services branded community support material 3\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery4Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-6.jpg\" alt=\"Empowered Community Services branded community support material 4\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-5.jpg\" alt=\"Empowered Community Services branding application 5\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-9.jpg\" alt=\"Empowered Community Services branding application 6\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-8.jpg\" alt=\"Empowered Community Services branding application 7\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Empowered Community Services</strong> se fundó en 2017 y ofrece apoyo individualizado de alta calidad dentro del NDIS, ayudando a personas con discapacidad a desarrollar autonomía, independencia y una participación más fuerte en sus comunidades.\n        </p>\n\n        <p>\nTrabajo con Empowered desde su inicio: primero desarrollé el branding y después fui ampliando ese sistema a medida que la organización crecía. Con el tiempo, el trabajo creativo se ha extendido a señalética, banners, merchandising, rotulación de vehículos, folletos, murales y otras aplicaciones de marca.\n        </p>\n\n        <p>\nDurante todo el proyecto, el objetivo fue construir una marca que se sintiera cálida, cercana y fiel a los valores de la empresa y a su fuerte implicación con la comunidad. Esa relación ha continuado con los años, y a día de hoy sigo llevando una parte importante del trabajo creativo de Empowered.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Empowered Community Services</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Branding / Señalética / Impresión / Rotulación de vehículos / Merchandising / Murales</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Servicios comunitarios / NDIS</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Relación</div>\n          <div class=\"portfolio-project-ctm__value\">Soporte creativo continuo desde 2017</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-17.jpg\" alt=\"Empowered Community Services branded signage or mural design 8\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-15.jpg\" alt=\"Empowered Community Services branded signage or mural design 9\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-19.jpg\" alt=\"Empowered Community Services branded signage or mural design 10\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-18.jpg\" alt=\"Empowered Community Services branded signage or mural design 11\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-14.jpg\" alt=\"Empowered Community Services branded signage or mural design 12\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/ECS-16.jpg\" alt=\"Empowered Community Services branded signage or mural design 13\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/ECS-2.jpg\" alt=\"Empowered Community Services branding rollout example 14\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/ECS-3.jpg\" alt=\"Empowered Community Services branding rollout example 15\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__video portfolio-project-ctm__video--full\">\n      <iframe allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\" frameborder=\"0\" src=\"https://www.youtube.com/embed/Lmx7ymffzwc\" title=\"Empowered Community Services video\">\n      </iframe>\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://empoweredcommunityservices.com\" rel=\"noopener\" target=\"_blank\">empoweredcommunityservices.com</a>\n    </div>\n<br />\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/paragon-bm/\">Ver proyecto de marca</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/biggs/\">Ver proyecto relacionado</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/kryoz/\">Ver proyecto para servicios</a></li>\n      </ul>\n    </div>\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/newy-fried-chicken/\">\n          <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n          <span class=\"portfolio-project-ctm__nav-title\">Newy Fried Chicken</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/biggs/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Biggs Coffee</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Empowered Community Services | Portfolio en Español | Mitch Chadban"
  description="Branding y soporte creativo continuo para Empowered Community Services, con señalética, impresión y aplicaciones de marca."
  canonical="https://mitchchadban.com/es/portfolio/empowered-community-services/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/empowered-community-services/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/empowered-community-services/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/empowered-community-services/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
