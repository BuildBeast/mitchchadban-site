---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Dirección creativa / merchandising / conceptos de interiorismo</div>\n      <h1>Yellow Billy &#x26; The Sty</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nConceptos creativos, merchandising e ideas de interiorismo desarrollados para Yellow Billy: un restaurante del Hunter Valley impulsado por el fuego y construido alrededor de la atmósfera, el carácter y la cocina a la llama.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-6.jpg\" alt=\"Flame shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-5.jpg\" alt=\"Skull shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-4.jpg\" alt=\"Vintage shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-3.jpg\" alt=\"Yellow Billy shirt for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/YB-2.jpg\" alt=\"ilustración of Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-10.jpg\" alt=\"Skull ilustración for Yellow Billy\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/YB-9.jpg\" alt=\"Female Yellow billy Illustartion\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Yellow Billy</strong> es uno de los restaurantes más destacados de Pokolbin, conocido por su cocina al fuego y por una atmósfera muy marcada. El proyecto se centró en desarrollar ideas de interiorismo y conceptos de merchandising capaces de reflejar esa identidad de una forma memorable, distintiva y fiel al venue.\n        </p>\n\n        <p>\nUna parte clave del atractivo del venue es su fire pit construido a medida, que funciona tanto como herramienta práctica de cocina como gran pieza central visual. La dirección de diseño respondió a esa energía apostando por conceptos elementales, con mucho carácter, conectados con el espíritu más amplio de Yellow Billy como marca.\n        </p>\n\n        <p>\nEn todo el trabajo creativo, el objetivo fue crear piezas conectadas a una sola idea — Yellow Billy en sí misma — en lugar de una colección de activos sin relación entre sí. El resultado fue un conjunto de trabajo pensado para reforzar la atmósfera interior del venue, la dirección de merchandising y su personalidad general.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Yellow Billy &#x26; The Sty</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Dirección creativa / merchandising / conceptos de interiorismo</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Pokolbin, Hunter Valley</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/YB-7.jpg\" alt=\"Toastie illustration on coaster\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/YB-8.jpg\" alt=\"Toastie shirt design for the Sty\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__link\">\n      <a href=\"https://yellowbillyrestaurant.com\" rel=\"noopener\" target=\"_blank\">yellowbillyrestaurant.com</a>\n    </div>\n<br />\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/the-star-hotel/\">Diseño para hostelería</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/pinos-restaurant/\">Ver proyecto de restaurante</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/newy-fried-chicken/\">Ver proyecto relacionado</a></li>\n      </ul>\n    </div>\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/paragon-bm/\">\n          <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n          <span class=\"portfolio-project-ctm__nav-title\">Paragon BM</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/karl-jacobs/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Karl Jacobs</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Yellow Billy & The Sty | Portfolio en Español | Mitch Chadban"
  description="Conceptos creativos, merchandising e interiorismo para Yellow Billy: un restaurante con fuego, atmósfera y carácter."
  canonical="https://mitchchadban.com/es/portfolio/yellow-billy-the-sty/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/yellow-billy-the-sty/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/yellow-billy-the-sty/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/yellow-billy-the-sty/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
