---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Carteles / Diseño para eventos / Trabajo continuo</div>\n      <h1>Various Posters</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nUna colección en crecimiento de carteles recientes creados para fiestas, eventos y experiencias en directo, con toda la dirección de arte y el diseño llevados por mí.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-1.jpg\" alt=\"Event poster design from the Various Posters collection 1\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-2.jpg\" alt=\"Event poster design from the Various Posters collection 2\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/p-3.jpg\" alt=\"Event poster design from the Various Posters collection 3\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/P-4.jpg\" alt=\"Event poster design from the Various Posters collection 4\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Various Posters</strong> es una colección en curso de carteles recientes creados para fiestas, eventos y campañas promocionales. Las piezas responden a briefs y atmósferas distintas, pero todas comparten un enfoque basado en la composición sólida, el carácter visual y la claridad al comunicar.\n        </p>\n\n        <p>\nCada cartel combina dirección de arte y diseño con el objetivo de crear visuales para eventos que se sientan memorables, distintivos y ajustados a la energía de la ocasión, en lugar de depender de fórmulas promocionales genéricas.\n        </p>\n\n        <p>\nEsta sección seguirá creciendo con el tiempo a medida que se añadan nuevos trabajos de cartelería.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Various Posters</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Art Dirección / diseño de carteles / promoción de eventos</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Formato</div>\n          <div class=\"portfolio-project-ctm__value\">Carteles / Eventos / Fiestas</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Estado</div>\n          <div class=\"portfolio-project-ctm__value\">Continuo / Actualizado con regularidad</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/P-5.jpg\" alt=\"Event poster design from the Various Posters collection 5\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/biggs/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Biggs Coffee</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Portfolio</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Various Posters | Portfolio en Español | Mitch Chadban"
  description="Colección en crecimiento de carteles recientes para fiestas, eventos y experiencias en directo, con dirección de arte y diseño desarrollados íntegramente por Mitch Chadban."
  canonical="https://mitchchadban.com/es/portfolio/various-posters/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/various-posters/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/various-posters/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/various-posters/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
