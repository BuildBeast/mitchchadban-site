---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Hospitality / Ilustración / Diseño</div>\n      <h1>Pino’s Restaurant</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nVarias ilustraciones y piezas de diseño creadas para Pino’s, un clásico vegetariano histórico de Newcastle, NSW (ya cerrado).\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Pino-s1.jpg\" alt=\"Shirt design for Pinos restaurant\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/Pinos-4.jpg\" alt=\"Pasta ilustración design for Pinos restaurant\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__gallery3\">\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pino2.jpg\" alt=\"Menu design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pinos-3.jpg\" alt=\"Pattern design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n      <div class=\"portfolio-project-ctm__gallery3Item\">\n        <img class=\"zoomable\" src=\"/images/Pinos5.jpg\" alt=\"Menu design for Pinos\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Pino’s Restaurant</strong> incluyó una serie de trabajos de ilustración y diseño creados para reforzar la presencia visual del local. El proyecto se movía dentro del contexto hospitality, equilibrando carácter, calidez y un estilo visual reconocible en distintas piezas creativas.\n        </p>\n\n        <p>\nEl trabajo se centró en crear activos que se sintieran juguetones, memorables y alineados con la personalidad del restaurante, pero a la vez prácticos para su uso real en aplicaciones promocionales y de marca.\n        </p>\n\n        <p>\nSi estás en Newcastle, NSW, este sitio merecía totalmente la visita.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Pino’s Restaurant</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Ilustración / Diseño / Activos para hospitality</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Sector</div>\n          <div class=\"portfolio-project-ctm__value\">Hospitality</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Ubicación</div>\n          <div class=\"portfolio-project-ctm__value\">Newcastle, NSW</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/the-star-hotel/\">Diseño para hostelería</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/newy-fried-chicken/\">Ver proyecto relacionado</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/yellow-billy-the-sty/\">Ver trabajo de hostelería</a></li>\n      </ul>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/kryoz/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Kryoz Gardening</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/the-star-hotel/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">The Star Hotel</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Pino’s Restaurant | Portfolio en Español | Mitch Chadban"
  description="Ilustración y diseño para Pino’s Restaurant: activos visuales con carácter para un restaurante histórico de Newcastle."
  canonical="https://mitchchadban.com/es/portfolio/pinos-restaurant/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/pinos-restaurant/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/pinos-restaurant/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/pinos-restaurant/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
