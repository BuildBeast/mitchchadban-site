---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const pageContent = "<div class=\"portfolio-project-ctm\">\n  <div class=\"portfolio-project-ctm__inner\">\n\n    <div class=\"portfolio-project-ctm__head\">\n      <div class=\"portfolio-project-ctm__meta\">Ilustración / Apparel / Colaboración</div>\n      <h1>Karl Jacobs</h1>\n      <p class=\"portfolio-project-ctm__intro\">\nUna pequeña colección de apparel creada para el streamer de Twitch y YouTuber estadounidense Karl Jacobs, construida alrededor de ilustraciones lúdicas con temática de minigolf para camisetas oscuras serigrafiadas.\n      </p>\n    </div>\n\n    <hr />\n\n    <div class=\"portfolio-project-ctm__hero\">\n      <img class=\"zoomable\" src=\"/images/KJ-6.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 1\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__split\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-3.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 2\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-4.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 3\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__body\">\n      <div class=\"portfolio-project-ctm__main\">\n        <p>\n          <strong>Karl Jacobs</strong> fue un pequeño proyecto de apparel con temática de minigolf, creado para serigrafiar sobre una gama de camisetas oscuras. El brief pedía ilustraciones juguetonas, gráficas y fáciles de llevar, pero con suficiente carácter como para conectar con la audiencia de Karl Jacobs.\n        </p>\n\n        <p>\n          La dirección creativa se centró en que el artwork se sintiera divertido, contundente y listo para colección, en lugar de excesivamente complejo. El resultado fue un conjunto de ilustraciones pensado para funcionar limpio en impresión y, al mismo tiempo, sentirse distintivo y conectado con el concepto.\n        </p>\n      </div>\n\n      <aside class=\"portfolio-project-ctm__side\">\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Proyecto</div>\n          <div class=\"portfolio-project-ctm__value\">Karl Jacobs</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Alcance</div>\n          <div class=\"portfolio-project-ctm__value\">Ilustración / Gráficas para apparel</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Dirección</div>\n          <div class=\"portfolio-project-ctm__value\">Rish / Revolt Enterprises</div>\n        </div>\n\n        <div class=\"portfolio-project-ctm__card\">\n          <div class=\"portfolio-project-ctm__label\">Tema</div>\n          <div class=\"portfolio-project-ctm__value\">Minigolf / Colección serigrafiada</div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"portfolio-project-ctm__hero portfolio-project-ctm__hero--bottom\">\n      <img class=\"zoomable\" src=\"/images/KJ-5.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 4\" loading=\"lazy\" decoding=\"async\" width=\"1080\" height=\"692\">\n    </div>\n\n    <div class=\"portfolio-project-ctm__split portfolio-project-ctm__split--bottom\">\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-2.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 5\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n      <div class=\"portfolio-project-ctm__splitItem\">\n        <img class=\"zoomable\" src=\"/images/KJ-1.jpg\" alt=\"Karl Jacobs mini golf apparel illustration 6\" loading=\"lazy\" decoding=\"async\" width=\"809\" height=\"1080\">\n      </div>\n    </div>\n\n    <div class=\"portfolio-project-ctm__related\">\n      <h3>Proyectos relacionados</h3>\n      <ul class=\"further-reading-ctm__list\">\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/kryoz/\">Ver proyecto de ilustración</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/johnny-bird/\">Ver personaje relacionado</a></li>\n        <li class=\"further-reading-ctm__item\"><a class=\"further-reading-ctm__link\" href=\"/es/portfolio/various-posters/\">Ver trabajo visual</a></li>\n      </ul>\n    </div>\n\n    <div class=\"portfolio-project-ctm__footer\">\n      <a class=\"portfolio-project-ctm__back\" href=\"/es/portfolio/\">Volver al portfolio</a>\n    </div>\n\n    <div class=\"portfolio-project-ctm__nav\">\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--prev\" href=\"/es/portfolio/yellow-billy-the-sty/\" >\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto anterior</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Yellow Billy &#x26; The Sty</span>\n      </a>\n\n      <a class=\"portfolio-project-ctm__nav-item portfolio-project-ctm__nav-item--next\" href=\"/es/portfolio/johnny-bird/\">\n        <span class=\"portfolio-project-ctm__nav-label\">Proyecto siguiente</span>\n        <span class=\"portfolio-project-ctm__nav-title\">Johnny Bird</span>\n      </a>\n    </div>\n\n  </div>\n</div>";
---

<BaseLayout
  lang="es"
  title="Karl Jacobs | Portfolio en Español | Mitch Chadban"
  description="Colección de apparel para Karl Jacobs con ilustraciones de minigolf pensadas para serigrafía sobre camisetas oscuras."
  canonical="https://mitchchadban.com/es/portfolio/karl-jacobs/"
  alternates={[
    { lang: 'en-AU', href: 'https://mitchchadban.com/karl-jacobs/' },
    { lang: 'es', href: 'https://mitchchadban.com/es/portfolio/karl-jacobs/' },
    { lang: 'x-default', href: 'https://mitchchadban.com/karl-jacobs/' }
  ]}
>
  <Fragment set:html={pageContent} />
</BaseLayout>
