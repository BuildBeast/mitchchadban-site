---
type Props = { lang?: string };
const { lang = 'en-AU' } = Astro.props;
const isEs = lang.startsWith('es');

const nav = isEs
  ? {
      portfolio: { href: '/portfolio-1/', label: 'TRABAJO' },
      services: { href: '/servicios-principales/', label: 'SERVICIOS' },
      blog: { href: '/es/blog/', label: 'BLOG' },
      contact: { href: '/contacto/', label: 'CONTACTO' }
    }
  : {
      portfolio: { href: '/portfolio-1/', label: 'PORTFOLIO' },
      services: { href: '/services-main/', label: 'SERVICES' },
      blog: { href: '/blogs-resources/', label: 'BLOG' },
      contact: { href: '/contact-form/', label: 'EMAIL' }
    };
const instagram = 'https://www.instagram.com/mitch_chadban/?hl=en';
---

<header class="header-web" role="banner">
  <div class="header-web__inner">
    <a class="header-web__brand" href="/">MITCH CHADBAN</a>

    <nav aria-label="Primary" class="header-web__nav">
      <a class="header-web__link" href={nav.portfolio.href}>{nav.portfolio.label}</a>
      <a class="header-web__link" href={nav.services.href}>{nav.services.label}</a>
      <a class="header-web__link" href={nav.blog.href}>{nav.blog.label}</a>
    </nav>

    <div class="header-web__meta">
      <a class="header-web__link header-web__link--muted" href={nav.contact.href}>{nav.contact.label}</a>
      <a class="header-web__link header-web__link--muted" href={instagram} rel="noopener" target="_blank">INSTAGRAM</a>
    </div>
  </div>
</header>

<hr class="header-rule" />

<header class="header-mob" role="banner">
  <details class="mobnav">
    <summary class="mobnav__bar">
      <a class="mobnav__brand" href="/">MITCH CHADBAN</a>

      <span aria-hidden="true" class="mobnav__btn">
        <span class="mobnav__icon"></span>
        <span class="mobnav__label">MENU</span>
      </span>

      <span aria-hidden="true" class="mobnav__x">✕</span>
    </summary>

    <div aria-hidden="true" class="mobnav__overlay"></div>

    <div aria-label="Mobile menu" class="mobnav__panel">
      <nav class="mobnav__links">
        <a href={nav.portfolio.href}>{isEs ? 'Trabajo' : 'Portfolio'}</a>
        <a href={nav.services.href}>{isEs ? 'Servicios' : 'Services'}</a>
        <a href={nav.blog.href}>Blog</a>
        <a href={nav.contact.href}>{isEs ? 'Contacto' : 'Email'}</a>
        <a href={instagram} rel="noopener" target="_blank">Instagram</a>
      </nav>

      <div class="mobnav__note">{isEs ? 'Trabajo nuevo, posts nuevos, sin relleno.' : 'New work, new posts, no fluff.'}</div>
    </div>
  </details>
</header>

<hr class="header-rule" />

<script>
(function () {

  function closeMobileMenus() {
    document.querySelectorAll(".mobnav").forEach((nav) => {
      nav.removeAttribute("open");
    });
  }

  // Close immediately
  closeMobileMenus();

  // Close after DOM ready
  document.addEventListener("DOMContentLoaded", closeMobileMenus);

  // Safari back/forward cache weirdness
  window.addEventListener("pageshow", closeMobileMenus);

})();
</script>
