---
type Props = { lang?: string };
const { lang = 'en-AU' } = Astro.props;
const isEs = lang.startsWith('es');

const instagram = 'https://www.instagram.com/mitch_chadban/?hl=en';
const t = isEs
  ? {
      tagline: 'Diseño, SEO y marketing para marcas que quieren destacar.',
      explore: 'EXPLORAR',
      portfolio: 'Trabajo',
      archive: 'Archivo',
      services: 'Servicios',
      blog: 'Blog',
      work: 'TRABAJO',
      contact: 'Contacto',
      pricing: 'Precios',
      about: 'Sobre mí',
      connect: 'CONECTAR',
      email: 'Email',
      privacy: 'Privacidad',
      terms: 'Términos',
      links: {
        portfolio: '/portfolio-1/',
        archive: '/archive/',
        services: '/servicios-principales/',
        blog: '/proximamente/',
        contact: '/contacto/',
        pricing: '/precios-y-paquetes/',
        about: '/acerca-de/',
        email: 'mailto:mitch.chadban@hotmail.com',
        privacy: '/politica-de-privacidad/',
        terms: '/terminos-de-servicio/'
      }
    }
  : {
      tagline: 'Design + marketing for brands that want to stand out.',
      explore: 'EXPLORE',
      portfolio: 'Portfolio',
      archive: 'Archive',
      services: 'Services',
      blog: 'Blog',
      work: 'WORK',
      contact: 'Contact',
      pricing: 'Pricing',
      about: 'About',
      connect: 'CONNECT',
      email: 'Email',
      privacy: 'Privacy',
      terms: 'Terms',
      links: {
        portfolio: '/portfolio-1/',
        archive: '/archive/',
        services: '/services-main/',
        blog: '/blogs-resources/',
        contact: '/contact-form/',
        pricing: '/pricing-and-packages/',
        about: '/about/',
        email: 'mailto:mitch.chadban@hotmail.com',
        privacy: '/privacy-policy/',
        terms: '/terms-of-service/'
      }
    };
---

<footer class="footer-ctm" role="contentinfo">
  <div class="footer-ctm__inner">

    <div class="footer-ctm__brand">
      <div class="footer-ctm__name">MITCH CHADBAN</div>
      <div class="footer-ctm__tagline">{t.tagline}</div>
    </div>

    <nav aria-label="Footer" class="footer-ctm__cols">
      <div class="footer-ctm__col">
        <div class="footer-ctm__label">{t.explore}</div>
        <a class="" href={t.links.portfolio}>{t.portfolio}</a>
        <a class="" href={t.links.archive}>{t.archive}</a>
        <a class="" href={t.links.services}>{t.services}</a>
        <a class="" href={t.links.blog}>{t.blog}</a>
      </div>

      <div class="footer-ctm__col">
        <div class="footer-ctm__label">{t.work}</div>
        <a href={t.links.contact}>{t.contact}</a>
        <a class="" href={t.links.pricing}>{t.pricing}</a>
        <a class="" href={t.links.about}>{t.about}</a>
      </div>

      <div class="footer-ctm__col">
        <div class="footer-ctm__label">{t.connect}</div>
        <a href={t.links.email}>{t.email}</a>
        <a href={instagram} rel="noopener" target="_blank">Instagram</a>
      </div>
    </nav>

    <div class="footer-ctm__bottom">
      <div>© 2026 Mitch Chadban</div>
      <div class="footer-ctm__legal">
        <a href={t.links.privacy}>{t.privacy}</a>
        <a href={t.links.terms}>{t.terms}</a>
      </div>
    </div>

  </div>
</footer>
